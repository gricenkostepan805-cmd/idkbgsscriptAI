-- === ИНИЦИАЛИЗАЦИЯ ===
local rs = game:GetService("ReplicatedStorage")
local lp = game.Players.LocalPlayer
local REMOTE = rs:FindFirstChild("NetworkRemoteEvent") or rs:FindFirstChild("RemoteEvent")
local EGGS_PATH = rs:FindFirstChild("Assets") and rs.Assets:FindFirstChild("Eggs") or rs:FindFirstChild("Eggs")
local PICKUPS = workspace:FindFirstChild("Pickups")

-- === ФУНКЦИЯ СТИЛЯ (КОТ + СТЕКЛО) ===
local function ApplyCustomStyle(id)
    local coreGui = game:GetService("CoreGui")
    for _, gui in pairs(coreGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui:FindFirstChild("Main") then
            local main = gui.Main
            if main:FindFirstChild("CustomBG") then main.CustomBG:Destroy() end
            local bg = Instance.new("ImageLabel", main)
            bg.Name = "CustomBG"
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.ZIndex = 0
            bg.BackgroundTransparency = 1
            bg.Image = "rbxassetid://" .. id
            bg.ImageTransparency = 0.2
            bg.ScaleType = Enum.ScaleType.Stretch
            Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 10)
            
            for _, child in pairs(main:GetDescendants()) do
                if child:IsA("Frame") or child:IsA("ScrollingFrame") then
                    child.BackgroundTransparency = 0.8
                    child.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
                elseif child:IsA("TextButton") then
                    if not child:FindFirstChild("UICorner") then Instance.new("UICorner", child).CornerRadius = UDim.new(0, 6) end
                    child.BackgroundTransparency = 0.5
                    child.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
                    child.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end
        end
    end
end

-- === ВКЛАДКИ ===
local Main = Window:NewTab("Main 🏠")
