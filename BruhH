-- === ЗАПОЛНЯЕМ SETTINGS (ВЕРНУЛ СМЕНУ ID) ===
local BgSection = Settings:NewSection("Кастомизация")
BgSection:NewTextBox("Сменить ID Фона", "Вставь ID и жми Enter", function(txt)
