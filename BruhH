-- === ФУНКЦИЯ ВЗЛОМА (Безопасная) ===
local function ActivatePasses()
    local count = 0
    for _, f in pairs(getgc()) do
        if type(f) == "function" then
            local upvalues = debug.getupvalues(f)
            for i, v in pairs(upvalues) do
                if type(v) == "table" and (rawget(v, "Quantum Gum") ~= nil or rawget(v, "+500 Slots") ~= nil) then
                    for passName, val in pairs(v) do
                        -- Меняем на true только если это не ID картинки (число/строка с assetid)
                        if type(val) == "boolean" then
                            v[passName] = true
                            count = count + 1
                        end
                    end
                    debug.setupvalue(f, i, v)
                end
            end
        end
    end
    print("AI: Активировано - " .. count)
end

