local function applyESP(v)
    pcall(function()
        local touch = v:FindFirstChildWhichIsA("TouchTransmitter", true)
        if touch and touch.Parent and not v:FindFirstChild("AtlasESP") then
            local p = touch.Parent; p.Size = Vector3.new(25, 25, 25); p.Transparency = 1; p.CanCollide = false
            local ui = Instance.new("BillboardGui", v); ui.Name = "AtlasESP"; ui.AlwaysOnTop = true; ui.Size = UDim2.new(0, 8, 0, 8)
            local dot = Instance.new("Frame", ui); dot.Size = UDim2.new(1, 0, 1, 0); dot.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0); Instance.new("UIStroke", dot).Color = Color3.new(1, 1, 1)
        end
    end)
end
task.spawn(function() while task.wait(1) do if hitboxExpanderEnabled and ACTUAL_PICKUPS then for _, v in pairs(ACTUAL_PICKUPS:GetChildren()) do applyESP(v) end end end end)
StartBtn.MouseButton1Click:Connect(function()
    if selectedEgg == "" then return end
    isHatching = not isHatching; StartBtn.Text = isHatching and "STOP HATCH" or "START HATCHING"
    StartBtn.BackgroundColor3 = isHatching and Color3.fromRGB(200, 60, 60) or Color3.fromRGB(0, 150, 90)
end)
