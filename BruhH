-- 🔄 ЦИКЛ СБОРА
task.spawn(function()
    while true do
        task.wait(2)
        if not autoCollectEnabled or not ACTUAL_PICKUPS then continue end
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local savedPos = root.CFrame
        for _, item in pairs(ACTUAL_PICKUPS:GetDescendants()) do
            if not autoCollectEnabled then break end
            if item:IsA("TouchTransmitter") then
                local part = item.Parent
                if part and part:IsA("BasePart") then
                    root.CFrame = part.CFrame
                    task.wait(0.05)
                end
            end
        end
        root.CFrame = savedPos
    end
end)

-- 🛠 ИСПРАВЛЕННЫЙ FAST OPEN (BGS GHOST METHOD)
task.spawn(function()
    while task.wait(0.1) do
        if fastOpenEnabled then
            -- Скрываем UI открытия
            for _, gui in pairs(LP.PlayerGui:GetDescendants()) do
                if gui.Name == "EggOpen" or gui.Name == "EggOpenGui" then
                    if gui:IsA("Frame") then gui.Visible = false
                    elseif gui:IsA("ScreenGui") then gui.Enabled = false end
                end
            end
            -- Прячем 3D яйца (увод под карту вместо Destroy)
            for _, v in pairs(WS:GetChildren()) do
                if v.Name == "Egg" and v:IsA("Model") then
                    for _, p in pairs(v:GetDescendants()) do
                        if p:IsA("BasePart") then p.Transparency = 1 p.CanCollide = false end
                    end
                    if v.PrimaryPart then v:SetPrimaryPartCFrame(CFrame.new(0, -1000, 0)) end
                end
            end
        end
    end
end)

