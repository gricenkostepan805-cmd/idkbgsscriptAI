    if id then ApplyCustomStyle(id) end
end)

-- === ЗАПОЛНЯЕМ MAIN ===
local MainSection = Main:NewSection("Автоматизация")
local autoCollect = false
MainSection:NewToggle("Auto Collect (Pickups)", "Притягивает монеты", function(state)
    autoCollect = state
    task.spawn(function()
        while autoCollect do
            if PICKUPS then
                for _, item in pairs(PICKUPS:GetChildren()) do
                    if item:IsA("BasePart") and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        item.CFrame = lp.Character.HumanoidRootPart.CFrame
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end)

MainSection:NewSlider("WalkSpeed", "Скорость бега", 500, 16, function(s)
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        lp.Character.Humanoid.WalkSpeed = s
    end
end)

-- === ВЗЛОМ ===
local HackSection = Hack:NewSection("Взлом геймпассов")
HackSection:NewButton("Unlock All Passes", "Активация через Upvalues", function()
    local count = 0
    for _, f in pairs(getgc()) do
        if type(f) == "function" and islclosure(f) then
            local upvals = debug.getupvalues(f)
            for i, v in pairs(upvals) do
                if type(v) == "table" and (rawget(v, "Quantum Gum") ~= nil or rawget(v, "+500 Slots") ~= nil) then
                    for pName, val in pairs(v) do if type(val) == "boolean" then v[pName] = true count = count + 1 end end
                    debug.setupvalue(f, i, v)
                end
            end
        end
    end
    game:GetService("StarterGui"):SetCore("SendNotification", {Title = "AI: Успех", Text = "Включено: "..tostring(count), Duration = 5})
end)

