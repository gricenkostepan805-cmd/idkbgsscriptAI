StartBtn.MouseButton1Click:Connect(function()
    if selectedEgg == "" then return end
    isHatching = not isHatching
    StartBtn.Text = isHatching and "STOP" or "START HATCH"
    StartBtn.BackgroundColor3 = isHatching and Color3.fromRGB(200, 50, 50) or Color3.fromRGB(0, 150, 80)
end)

-- 🔄 ИСПРАВЛЕННЫЙ ЦИКЛ СБОРА (Прыжок-Возврат)
task.spawn(function()
    while true do
        task.wait(2) -- Собираем раз в 2 секунды, чтобы не кикало
        if not autoCollectEnabled or not ACTUAL_PICKUPS then continue end
        
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local savedPos = root.CFrame -- Сохраняем позицию у яиц

        for _, item in pairs(ACTUAL_PICKUPS:GetDescendants()) do
            if not autoCollectEnabled then break end
            if item:IsA("TouchTransmitter") then
                local part = item.Parent
                if part and part:IsA("BasePart") then
                    root.CFrame = part.CFrame -- Прыгаем к монете
                    task.wait(0.05) -- Даем серверу "увидеть" нас
                end
            end
        end
        
        root.CFrame = savedPos -- Возвращаемся к яйцам
    end
end)

-- Hatching & Fast Open
task.spawn(function()
    while true do
        if isHatching and selectedEgg ~= "" then REMOTE:FireServer("PurchaseEgg", selectedEgg, "Multi") end
        task.wait(0.01)
    end
end)
