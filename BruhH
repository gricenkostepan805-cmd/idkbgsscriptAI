local function updateList(filter)
    for _, child in pairs(ScrollFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    local eggs = {}
    if EGGS_PATH then for _, v in pairs(EGGS_PATH:GetChildren()) do if filter == "" or v.Name:lower():find(filter:lower()) then table.insert(eggs, v.Name) end end end
    table.sort(eggs)
    for _, name in pairs(eggs) do
        local b = Instance.new("TextButton", ScrollFrame)
        b.Size = UDim2.new(1, -5, 0, 30); b.BackgroundTransparency = 1; b.Text = "  " .. name
        b.TextColor3 = Color3.new(0.9, 0.9, 0.9); b.Font = Enum.Font.Gotham; b.TextSize = 12; b.TextXAlignment = Enum.TextXAlignment.Left
        b.MouseButton1Click:Connect(function() selectedEgg = name; _G.LastEgg = "EGG: " .. name; ListFrame.Visible = false end)
    end
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #eggs * 32)
end
SearchBox:GetPropertyChangedSignal("Text"):Connect(function() updateList(SearchBox.Text) end)

