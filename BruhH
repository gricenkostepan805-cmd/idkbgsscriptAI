local tabs = {}
local function createTab(name, dName)
    local f = Instance.new("ScrollingFrame", Container)
    f.Size = UDim2.new(1, 0, 1, 0)
    f.BackgroundTransparency = 1
    f.Visible = false
    f.ScrollBarThickness = 2
    local Layout = Instance.new("UIListLayout", f)
    Layout.Padding = UDim.new(0, 5)

    local b = Instance.new("TextButton", Nav)
    b.Size = UDim2.new(0.333, 0, 1, 0)
    b.BackgroundTransparency = 1
    b.Text = dName:upper()
    b.TextColor3 = Color3.new(0.6, 0.6, 0.6)
    b.Font = Enum.Font.GothamMedium
    b.TextSize = 10

    b.MouseButton1Click:Connect(function()
        for _, tab in pairs(tabs) do tab.Visible = false end
        for _, btn in pairs(Nav:GetChildren()) do if btn:IsA("TextButton") then btn.TextColor3 = Color3.new(0.6,0.6,0.6) end end
        f.Visible = true
        b.TextColor3 = Color3.fromRGB(0, 180, 255)
    end)
    tabs[name] = f
    return f
end

