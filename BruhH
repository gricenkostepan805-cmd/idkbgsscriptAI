-- Чекбоксы
local function addCheck(parent, txt, callback)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(1, 0, 0, 25); f.BackgroundTransparency = 1
    local c = Instance.new("TextButton", f); c.Size = UDim2.new(0, 20, 0, 20); c.BackgroundColor3 = Color3.fromRGB(30, 35, 45); c.Text = ""
    c.TextColor3 = Color3.fromRGB(0, 180, 255); Instance.new("UICorner", c).CornerRadius = UDim.new(0, 4)
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, -30, 1, 0); l.Position = UDim2.new(0, 30, 0, 0); l.BackgroundTransparency = 1
    l.Text = txt; l.TextColor3 = Color3.new(0.9, 0.9, 0.9); l.Font = Enum.Font.Gotham; l.TextSize = 12; l.TextXAlignment = Enum.TextXAlignment.Left
    local active = false; c.MouseButton1Click:Connect(function() active = not active; c.Text = active and "●" or ""; callback(active) end)
end

