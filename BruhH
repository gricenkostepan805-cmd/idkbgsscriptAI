-- Вспомогательная функция для чекбоксов (из твоего кода)
local function addCheck(parent, text, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, 0, 0, 25)
    f.BackgroundTransparency = 1
    local b = Instance.new("TextButton", f)
    b.Size = UDim2.new(0, 20, 0, 20)
    b.Position = UDim2.new(0, 0, 0, 2)
    b.BackgroundColor3 = Color3.fromRGB(30, 35, 45)
    b.Text = ""
    Instance.new("UICorner", b)
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1, -30, 1, 0)
    t.Position = UDim2.new(0, 30, 0, 0)
    t.Text = text
    t.TextColor3 = Color3.new(0.9, 0.9, 0.9)
    t.Font = Enum.Font.Gotham
    t.TextSize = 12
    t.BackgroundTransparency = 1
    t.TextXAlignment = Enum.TextXAlignment.Left

    local active = false
    b.MouseButton1Click:Connect(function()
        active = not active
        b.BackgroundColor3 = active and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(30, 35, 45)
        callback(active)
    end)
end

