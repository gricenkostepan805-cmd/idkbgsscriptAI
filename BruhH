task.spawn(function()
    while task.wait(1) do
        pcall(function()
            local ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
            PingLabel.Text = "Ping: " .. ping .. " ms"
            local diff = tick() - startTime
            TimeLabel.Text = string.format("Runtime: %02d:%02d:%02d", math.floor(diff/3600), math.floor((diff%3600)/60), math.floor(diff%60))
        end)
    end
end)

task.spawn(function()
    while true do
        if isHatching and selectedEgg ~= "" then 
            REMOTE:FireServer("PurchaseEgg", selectedEgg, "Multi") 
            eggsOpened = eggsOpened + 3
            EggStatLabel.Text = "Eggs Opened: " .. eggsOpened
        end
        task.wait(0.05) -- Чуть увеличил задержку для стабильности
    end
end)

task.spawn(function()
    while true do
        task.wait(2)
        if autoCollectEnabled and ACTUAL_PICKUPS then
            local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local oldPos = root.CFrame
                for _, item in pairs(ACTUAL_PICKUPS:GetDescendants()) do
                    if not autoCollectEnabled then break end
                    if item:IsA("TouchTransmitter") and item.Parent then
                        root.CFrame = item.Parent.CFrame
                        task.wait(0.05)
                    end
                end
                root.CFrame = oldPos
            end
        end
    end
end)

