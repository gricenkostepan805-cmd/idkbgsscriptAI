local Tabs = {}
local function createTab(name, dName)
    local f = Instance.new("Frame", Container); f.Size = UDim2.new(1, 0, 1, 0); f.BackgroundTransparency = 1; f.Visible = false
    Instance.new("UIListLayout", f).Padding = UDim.new(0, 10); Tabs[name] = f
    local b = Instance.new("TextButton", Nav); b.Size = UDim2.new(0.333, 0, 1, 0); b.BackgroundTransparency = 1
    b.Text = dName:upper(); b.TextColor3 = Color3.new(0.6, 0.6, 0.6); b.Font = Enum.Font.GothamMedium; b.TextSize = 10
    b.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do t.Visible = false end; f.Visible = true
        for _, btn in pairs(Nav:GetChildren()) do if btn:IsA("TextButton") then btn.TextColor3 = Color3.new(0.6,0.6,0.6) end end
        b.TextColor3 = Color3.fromRGB(0, 180, 255)
        ListFrame.Visible = false -- ФИКС: Закрываем список при смене вкладок
    end)
    return f
end

