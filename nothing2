	baseData.honey = 0
	baseData.Pollen = 0
	baseData.pollen = 0
	baseData.Capacity = 200
	baseData.TotalHoney = 0
	baseData.DailyHoney = 0
	baseData.Tickets = 0

	-- [ВЫЖИГАЕМ АБУЗУ]: Выставляем параметры в чистый nil/пустоту, 
	-- чтобы сработал Онеттовский авто-фоллбэк на Scooper и Pouch на клиенте!
