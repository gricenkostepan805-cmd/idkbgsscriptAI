		Totals = { Stickers = { AnyCreated = 0, AnyReceived = 0, AnyTraded = 0, AddedToInbox = 0, HiddenFound = {}, Received = {}, Traded = {}, Discarded = {}, PutOnBoard = {} }, Kills = {}, Goo = { All = 0, Colors = {}, Zones = {} }, Pollen = {}, Tokens = {}, Bees = {} },
		Amulets = {}, Beequips = {}
