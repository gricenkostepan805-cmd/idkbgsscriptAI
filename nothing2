-- MovementSafetyNet: Ensures player can always move after loading
-- Fixes: ControlScript not finishing, stray LoadingScreenGui, movement stuck disabled
-- Key fix: Calls mc:Init() to bind the MasterControl render step if ControlScript failed

-- Wrap everything in a pcall so errors don't silently kill the script
local safetyNetOk, safetyNetErr = pcall(function()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

print("[MovementSafetyNet] Script starting...")

-- Wait for LocalPlayer
local player = Players.LocalPlayer
if not player then
    Players:GetPropertyChangedSignal("LocalPlayer"):Wait()
    player = Players.LocalPlayer
end
print("[MovementSafetyNet] LocalPlayer found")

-- Wait for character to load
local character = player.Character or player.CharacterAdded:Wait()
print("[MovementSafetyNet] Character found")

-- Get references
local playerGui = player:WaitForChild("PlayerGui", 10)
local playerScripts = player:WaitForChild("PlayerScripts", 15)
print("[MovementSafetyNet] PlayerScripts found")

-- ============================================================
-- STEP 1: Ensure MasterControl render step is bound
-- This is THE critical fix - ControlScript often fails before
-- calling mc:Init(), so the render step never gets bound
-- ============================================================
print("[MovementSafetyNet] Waiting for ControlScript...")
local controlScript = nil
local masterControlModule = nil

-- Wait for ControlScript to appear in PlayerScripts (it gets copied from StarterPlayerScripts)
if playerScripts then
    local waitStart = tick()
    while (tick() - waitStart) < 10 do
        controlScript = playerScripts:FindFirstChild("ControlScript")
        if controlScript then
            masterControlModule = controlScript:FindFirstChild("MasterControl")
            if masterControlModule then break end
        end
        task.wait(0.5)
    end
end

if masterControlModule then
    print("[MovementSafetyNet] Found ControlScript and MasterControl")
    local ok, mc = pcall(function() return require(masterControlModule) end)
    if ok and mc then
        -- Wait up to 3 seconds for ControlScript to set ControlState
        local waitStart = tick()
        while mc.ControlState == nil and (tick() - waitStart) < 3 do
            task.wait(0.25)
        end
        
        -- STEP 1a: If ControlState is nil, set it up manually
        if mc.ControlState == nil then
            warn("[MovementSafetyNet] ControlState is nil - setting up manually")
            
            local controlState = {
                Current = nil,
                SwitchTo = function(self, newModule)
                    if self.Current ~= newModule then
                        if self.Current then
                            pcall(function() self.Current:Disable() end)
                        end
                        self.Current = newModule
                        if self.Current then
                            pcall(function() self.Current:Enable() end)
                        end
                    end
                end,
                IsTouchJumpModuleUsed = function(_)
                    return false
                end
            }
            
            mc.ControlState = controlState
            
            -- Set up TouchJumpModule
            local touchJumpModule = masterControlModule:FindFirstChild("TouchJump")
            if touchJumpModule then
                pcall(function() mc.TouchJumpModule = require(touchJumpModule) end)
            end
            
            -- Try to use the real KeyboardMovement module
            local kbMovement = nil
            pcall(function() kbMovement = require(masterControlModule:FindFirstChild("KeyboardMovement")) end)
            
            if kbMovement then
                -- Create a keyboard module wrapper that ControlScript's Keyboard.Enable would create
                local keyboardModule = {
                    LocalPlayerChangedCon = nil,
                    GameSettingsChangedCon = nil
                }
                function keyboardModule:Enable()
                    pcall(function() kbMovement:Enable() end)
                end
                function keyboardModule:Disable()
                    pcall(function() kbMovement:Disable() end)
                end
                function keyboardModule:DisconnectEvents()
                    if self.LocalPlayerChangedCon then
                        pcall(function() self.LocalPlayerChangedCon:disconnect() end)
                        self.LocalPlayerChangedCon = nil
                    end
                    if self.GameSettingsChangedCon then
                        pcall(function() self.GameSettingsChangedCon:disconnect() end)
                        self.GameSettingsChangedCon = nil
                    end
                end
                function keyboardModule:RefreshControlStyle()
                    self:Disable()
                    self:Enable()
                end
                controlState:SwitchTo(keyboardModule)
            else
                warn("[MovementSafetyNet] KeyboardMovement module failed to load - using direct input fallback")
                -- Direct keyboard input fallback - bypasses the broken module system entirely
                local UIS = game:GetService("UserInputService")
                local moveVector = Vector3.new(0, 0, 0)
                
                local directKeyboard = {
                    moveDir = Vector3.new(0, 0, 0)
                }
                
                function directKeyboard:Enable()
                    self._inputConn = UIS.InputBegan:Connect(function(input, processed)
                        if processed then return end
                        if input.KeyCode == Enum.KeyCode.W then
                            self.moveDir = self.moveDir + Vector3.new(0, 0, -1)
                        elseif input.KeyCode == Enum.KeyCode.S then
                            self.moveDir = self.moveDir + Vector3.new(0, 0, 1)
                        elseif input.KeyCode == Enum.KeyCode.A then
                            self.moveDir = self.moveDir + Vector3.new(-1, 0, 0)
                        elseif input.KeyCode == Enum.KeyCode.D then
                            self.moveDir = self.moveDir + Vector3.new(1, 0, 0)
                        elseif input.KeyCode == Enum.KeyCode.Space then
                            local char = player.Character
                            local hum = char and char:FindFirstChildOfClass("Humanoid")
                            if hum then hum.Jump = true end
                        end
                    end)
                    self._inputEndConn = UIS.InputEnded:Connect(function(input, processed)
                        if input.KeyCode == Enum.KeyCode.W then
                            self.moveDir = self.moveDir - Vector3.new(0, 0, -1)
                        elseif input.KeyCode == Enum.KeyCode.S then
                            self.moveDir = self.moveDir - Vector3.new(0, 0, 1)
                        elseif input.KeyCode == Enum.KeyCode.A then
                            self.moveDir = self.moveDir - Vector3.new(-1, 0, 0)
                        elseif input.KeyCode == Enum.KeyCode.D then
                            self.moveDir = self.moveDir - Vector3.new(1, 0, 0)
                        end
                    end)
                    self._renderConn = RunService.RenderStepped:Connect(function()
                        mc:AddToPlayerMovement(-mc:GetMoveVector())
                        mc:AddToPlayerMovement(self.moveDir)
                    end)
                end
                function directKeyboard:Disable()
                    if self._inputConn then self._inputConn:Disconnect() self._inputConn = nil end
                    if self._inputEndConn then self._inputEndConn:Disconnect() self._inputEndConn = nil end
                    if self._renderConn then self._renderConn:Disconnect() self._renderConn = nil end
                end
                function directKeyboard:DisconnectEvents() end
                function directKeyboard:RefreshControlStyle() end
                
                controlState:SwitchTo(directKeyboard)
            end
            
            print("[MovementSafetyNet] ControlState manually set up")
        else
            print("[MovementSafetyNet] ControlState already set by ControlScript")
            
            -- STEP 1b: Even if ControlState is set, check if Current is nil
            -- This happens if ControlScript set ControlState but crashed before SwitchTo
            if mc.ControlState.Current == nil then
                warn("[MovementSafetyNet] ControlState.Current is nil - calling SwitchTo")
                local kbMovement = nil
                pcall(function() kbMovement = require(masterControlModule:FindFirstChild("KeyboardMovement")) end)
                if kbMovement then
                    local keyboardModule = {
                        LocalPlayerChangedCon = nil,
                        GameSettingsChangedCon = nil
                    }
                    function keyboardModule:Enable()
                        pcall(function() kbMovement:Enable() end)
                    end
                    function keyboardModule:Disable()
                        pcall(function() kbMovement:Disable() end)
                    end
                    function keyboardModule:DisconnectEvents()
                        if self.LocalPlayerChangedCon then
                            pcall(function() self.LocalPlayerChangedCon:disconnect() end)
                            self.LocalPlayerChangedCon = nil
                        end
                        if self.GameSettingsChangedCon then
                            pcall(function() self.GameSettingsChangedCon:disconnect() end)
                            self.GameSettingsChangedCon = nil
                        end
                    end
                    function keyboardModule:RefreshControlStyle()
                        self:Disable()
                        self:Enable()
                    end
                    mc.ControlState:SwitchTo(keyboardModule)
                end
            end
        end
        
        -- STEP 1c: CRITICAL - Ensure the render step is bound
        -- ControlScript often fails before calling mc:Init(), which means
        -- the MasterControlStep render step is never bound and movement
        -- never works even if everything else is set up correctly.
        -- We unbind first to avoid double-binding, then rebind.
        pcall(function() RunService:UnbindFromRenderStep("MasterControlStep") end)
        pcall(function() mc:Init() end)
        print("[MovementSafetyNet] MasterControl render step bound")
        
        -- STEP 2: Force-enable movement on MasterControl
        pcall(function() mc:Enable() end)
        
        -- STEP 3: Reset CameraTools movement counter
        -- If DisablePlayerMovement was called more times than EnablePlayerMovement,
        -- the counter stays positive and movement stays disabled.
        -- We call EnablePlayerMovement enough times to reset the counter.
        pcall(function()
            local cameraTools = game.ReplicatedStorage:FindFirstChild("CameraTools")
            if cameraTools then
                local ct = require(cameraTools)
                for i = 1, 10 do
                    ct.EnablePlayerMovement()
                end
            end
        end)
        
        print("[MovementSafetyNet] Movement fully enabled")
    else
        warn("[MovementSafetyNet] Failed to require MasterControl: " .. tostring(mc))
    end
else
    warn("[MovementSafetyNet] MasterControl module not found")
end

-- ============================================================
-- STEP 4: Clean up stray LoadingScreenGui instances
-- These can block input and keep the loading screen visible
-- ============================================================
local function cleanupLoadingScreen()
    -- Remove from PlayerGui
    if playerGui then
        local lsg = playerGui:FindFirstChild("LoadingScreenGui")
        if lsg then
            lsg.Enabled = false
            task.wait(0.3)
            if lsg and lsg.Parent then
                lsg:Destroy()
            end
            print("[MovementSafetyNet] Removed LoadingScreenGui from PlayerGui")
        end
    end
    
    -- Remove from PlayerScripts (this was the main culprit!)
    if playerScripts then
        local lsg2 = playerScripts:FindFirstChild("LoadingScreenGui")
        if lsg2 then
            lsg2:Destroy()
            print("[MovementSafetyNet] Removed LoadingScreenGui from PlayerScripts")
        end
    end
    
    -- Also remove from ReplicatedFirst if it somehow got parented there
    local rf = game.ReplicatedFirst:FindFirstChild("LoadingScreenGui")
    if rf then
        -- Don't destroy the template, just make sure it's not blocking
        rf.Enabled = false
    end
end

-- Clean up immediately and also after delays
task.spawn(cleanupLoadingScreen)
task.spawn(function()
    task.wait(3)
    cleanupLoadingScreen()
end)
task.spawn(function()
    task.wait(8)
    cleanupLoadingScreen()
end)

-- Watch for LoadingScreenGui being re-added
if playerGui then
    playerGui.ChildAdded:Connect(function(child)
        if child.Name == "LoadingScreenGui" then
            task.wait(2) -- Give the normal flow a chance to hide it
            if child and child.Parent and child.Enabled then
                child.Enabled = false
                task.wait(0.3)
                if child and child.Parent then
                    child:Destroy()
                end
                warn("[MovementSafetyNet] Force-removed re-added LoadingScreenGui")
            end
        end
    end)
end

-- Also watch PlayerScripts for LoadingScreenGui
if playerScripts then
    playerScripts.ChildAdded:Connect(function(child)
        if child.Name == "LoadingScreenGui" then
            child:Destroy()
            warn("[MovementSafetyNet] Destroyed LoadingScreenGui added to PlayerScripts")
        end
    end)
end

print("[MovementSafetyNet] Safety net initialized")

end) -- end of pcall wrapper

if not safetyNetOk then
    warn("[MovementSafetyNet] FATAL ERROR: " .. tostring(safetyNetErr))
    -- Last resort: try to enable movement directly
    pcall(function()
        local Players2 = game:GetService("Players")
        local player2 = Players2.LocalPlayer
        if player2 and player2.Character then
            local hum = player2.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = 16
                hum.JumpPower = 50
            end
        end
        -- Destroy any loading screen
        if player2 then
            local pg = player2:FindFirstChild("PlayerGui")
            if pg then
                local lsg = pg:FindFirstChild("LoadingScreenGui")
                if lsg then lsg:Destroy() end
            end
            local ps = player2:FindFirstChild("PlayerScripts")
            if ps then
                local lsg2 = ps:FindFirstChild("LoadingScreenGui")
                if lsg2 then lsg2:Destroy() end
            end
        end
    end)
end
