			end
		end)

		-- [ТOТ САМЫЙ АТОМНЫЙ ЗАЛП ДЛЯ ЗАПУСКА КЛИЕНТА]:
		pcall(function()
			eventsModule.ServerItemPackEvent:FireClient(plr, "Update", {Honey = bd.Honey or 0, Pollen = 0, Capacity = bd.Capacity or 200})
