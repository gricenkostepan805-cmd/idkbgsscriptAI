local function mkV(parent, vtype, name, val)
	local v = parent:FindFirstChild(name) or Instance.new(vtype)
	v.Name = name 
	if val ~= nil then v.Value = val end 
	v.Parent = parent 
	return v 
end

local function mkFolder(parent, name)
	local f = parent:FindFirstChild(name) or Instance.new("Folder")
	f.Name = name f.Parent = parent 
	return f 
end

-- ИСПРАВЛЕННАЯ СБОРКА АНАТОМИИ БСС (СТРОГО ЧЕРЕЗ ПЕРЕМЕННУЮ BASEDATA БЕЗ ПУТАНИЦЫ!)
local function buildBssAnatomy(targetParent, baseData)
	-- 1. Создаем CoreStats
	local coreStats = mkFolder(targetParent, "CoreStats")
	mkV(coreStats, "NumberValue", "Capacity", baseData.Capacity or 200)
	mkV(coreStats, "NumberValue", "Honey", baseData.Honey or 10000)
	mkV(coreStats, "NumberValue", "Pollen", baseData.Pollen or 0)

	-- 2. Создаем TradeConfig со всеми флагами из Dex
	local tradeConfig = mkFolder(targetParent, "TradeConfig")
	local tradeFlags = { {"CanTrade", true}, {"IsTrading", false}, {"RequestsEnabled", true} }
	for _, flag in ipairs(tradeFlags) do
		local boolVal = tradeConfig:FindFirstChild(flag[1]) or Instance.new("BoolValue")
		boolVal.Name = flag[1] boolVal.Value = flag[2] boolVal.Parent = tradeConfig
	end

	-- 3. Решётка ActivatableTarget
	mkV(targetParent, "ObjectValue", "ActivatableTarget")
end

