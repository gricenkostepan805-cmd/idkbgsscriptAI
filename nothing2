-- ============================================================
-- PROMO CODE SYSTEM
-- ============================================================

Events.ServerListen("PromoCodeEvent", function(player, code)
	if not code or type(code) ~= "string" or #code <= 0 or #code > 100 then
		pcall(function()
			Events.ServerCall("ReceiveAlert", player, "Invalid code!", Color3.fromRGB(255, 100, 100))
		end)
		return
	end

	local stats = playerCache[player]
	if not stats then return end

	if not stats.RedeemedCodes then
		stats.RedeemedCodes = {}
	end

	if stats.RedeemedCodes[code] then
		pcall(function()
			Events.ServerCall("ReceiveAlert", player, "Already redeemed!", Color3.fromRGB(255, 200, 100))
		end)
		return
	end

	-- Known promo codes (canonical BSS codes)
	local codeLower = string.lower(code)
	local knownCodes = {
		["10mil"] = { Honey = 10000 },
		["treats"] = { Items = { Treat = 5 } },
		["bees"] = { Eggs = { BasicEgg = 1 } },
		["honey"] = { Honey = 5000 },
		["tickets"] = { Tickets = 5 },
	}

	local reward = knownCodes[codeLower]
	if reward then
		stats.RedeemedCodes[code] = true

		if reward.Honey then
			stats.Honey = (stats.Honey or 0) + reward.Honey
		end
		if reward.Tickets then
			stats.Tickets = (stats.Tickets or 0) + reward.Tickets
		end
		if reward.Eggs then
			stats.Eggs = stats.Eggs or {}
			for eggType, amount in pairs(reward.Eggs) do
				stats.Eggs[eggType] = (stats.Eggs[eggType] or 0) + amount
			end
		end
		if reward.Items then
			stats.Items = stats.Items or {}
			for itemType, amount in pairs(reward.Items) do
				stats.Items[itemType] = (stats.Items[itemType] or 0) + amount
			end
		end

		syncCoreStats(player, stats)

		pcall(function()
			Events.ServerCall("ReceiveAlert", player, "Code redeemed successfully!", Color3.fromRGB(100, 255, 100))
		end)

		-- Trigger client stat cache reset
		pcall(function()
			local serverSystemEvent = ReplicatedStorage.Events:FindFirstChild("ServerSystemEvent")
			if serverSystemEvent then
				serverSystemEvent:FireClient(player, "FullCacheReset")
			end
		end)
	else
		pcall(function()
			Events.ServerCall("ReceiveAlert", player, "Invalid code!", Color3.fromRGB(255, 100, 100))
		end)
	end
end)

