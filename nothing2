-- ConstructHiveCellFromEgg: Hatches an egg and places a bee in the hive
Events.ServerListen("ConstructHiveCellFromEgg", function(player, eggType, cellIndex)
	local stats = playerCache[player]
	if not stats then return false, "No stats loaded" end

	-- Normalize egg type name (canonical BSS uses "Basic", "Silver", etc.)
	local egg = eggType or "Basic"
	if not stats.Eggs then stats.Eggs = {} end
	local eggCount = stats.Eggs[egg] or stats.Eggs[egg:gsub("%s", "")] or 0
	if eggCount <= 0 then
		return false, "No egg of type " .. tostring(egg)
	end

	-- Remove egg
	stats.Eggs[egg] = eggCount - 1
	if stats.Eggs[egg] <= 0 then stats.Eggs[egg] = nil end

	-- Determine bee type using EggTypes module (canonical mapping)
	local beeType = "BasicBee"
	local EggTypes = require(game.ReplicatedStorage.EggTypes)
	local eggData = EggTypes:GetType(egg)
	if eggData and eggData.BeeType then
		beeType = eggData.BeeType
	elseif egg and egg ~= "Basic" then
		-- Fallback: try to derive bee type from egg name
		beeType = egg .. "Bee"
	end

	-- Add to honeycomb
	if not stats.Honeycomb then stats.Honeycomb = {} end
	local beeEntry = { Type = beeType, Level = 1, ID = #stats.Honeycomb + 1 }
	if cellIndex and type(cellIndex) == "number" then
		stats.Honeycomb[cellIndex] = beeEntry
	else
		table.insert(stats.Honeycomb, beeEntry)
	end

	-- Track discovered bees
	if not stats.DiscoveredBees then stats.DiscoveredBees = {} end
	local found = false
	for _, v in ipairs(stats.DiscoveredBees) do
		if v == beeType then found = true break end
	end
	if not found then
		table.insert(stats.DiscoveredBees, beeType)
	end

	-- Update totals
	if stats.Totals then
		stats.Totals.TotalBeesDiscovered = (stats.Totals.TotalBeesDiscovered or 0) + 1
	end

	-- Trigger client cache reset
	pcall(function()
		local serverSystemEvent = ReplicatedStorage.Events:FindFirstChild("ServerSystemEvent")
		if serverSystemEvent then
			serverSystemEvent:FireClient(player, "FullCacheReset")
		end
	end)

	return true, beeType
end)

-- ItemPackageEvent: Handles item purchases and transactions
Events.ServerListen("ItemPackageEvent", function(player, action, data)
	local stats = playerCache[player]
	if not stats then return false, "No stats loaded" end

	if action == "Buy" or action == "Purchase" then
		local cost = data and data.Cost or 0
		if (stats.Honey or 0) >= cost then
			stats.Honey = (stats.Honey or 0) - cost
			local category = data.Category or data.Type
			local itemName = data.Item or data.Name
			if category == "Collectors" and itemName then
				if not stats.Collectors then stats.Collectors = {} end
				local alreadyHas = false
				for _, c in ipairs(stats.Collectors) do
					if c == itemName then alreadyHas = true break end
				end
				if not alreadyHas then
					table.insert(stats.Collectors, itemName)
				end
				stats.EquippedCollector = itemName
			elseif category == "Backpacks" and itemName then
				if not stats.Backpacks then stats.Backpacks = {} end
				local alreadyHas = false
				for _, b in ipairs(stats.Backpacks) do
					if b == itemName then alreadyHas = true break end
				end
				if not alreadyHas then
					table.insert(stats.Backpacks, itemName)
				end
				stats.EquippedBackpack = itemName
			elseif category == "Eggs" and itemName then
				if not stats.Eggs then stats.Eggs = {} end
				stats.Eggs[itemName] = (stats.Eggs[itemName] or 0) + (data.Amount or 1)
			end
			syncCoreStats(player, stats)
			return true
		end
		return false, "Not enough honey"
	elseif action == "Give" then
		return true
	elseif action == "Equip" then
		local category = data and data.Category
		local itemName = data and data.Item
		if category == "Collectors" and itemName then
			stats.EquippedCollector = itemName
			syncCoreStats(player, stats)
			return true
		elseif category == "Backpacks" and itemName then
			stats.EquippedBackpack = itemName
			syncCoreStats(player, stats)
			return true
		end
		return false, "Invalid equip request"
	end
	return nil
end)

