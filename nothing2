	cache[plr] = bd

	-- Sync to PlayerStatManager so RetrievePlayerStats returns proper data
	if PlayerStatManager and PlayerStatManager.SetStats then
		local psmStats = PlayerStatManager.GetStats(plr)
		if psmStats then
			psmStats.Honey = bd.Honey
			psmStats.Capacity = bd.Capacity
			psmStats.Pollen = bd.Pollen or 0
			psmStats.EquippedCollector = bd.EquippedCollector or "Scooper"
			psmStats.EquippedBackpack = bd.EquippedBackpack or "Pouch"
			psmStats.Gear = bd.Gear or { Tool = "Scooper", Backpack = "Pouch" }
			if bd.Eggs and psmStats.Eggs then
				for k, v in pairs(bd.Eggs) do psmStats.Eggs[k] = v end
			end
			cache[plr] = psmStats
		else
			PlayerStatManager.SetStats(plr, bd)
		end
	end

	-- [ДУБЛИРОВАНИЕ 1]: Вбиваем папки статов внутрь объекта Игрока (game.Players)
