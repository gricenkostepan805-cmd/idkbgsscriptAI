-- Сетевой модуль Онетта
local eventsModule = ReplicatedStorage:WaitForChild("Events")

local function getCanonicalRemote(name, className)
	local target = eventsModule:FindFirstChild(name)
	if target and not target:IsA(className) then
		target:Destroy()
		target = nil
	end
	if not target then
		target = Instance.new(className)
		target.Name = name
		target.Parent = eventsModule
	end
	return target
end

