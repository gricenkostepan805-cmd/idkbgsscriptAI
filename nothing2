-- ===== СВЯЩЕННЫЙ ЛOГГЕР СКРЫТЫХ ОШИБОК =====
local LOG_PREFIX = "[MainServer]"
local function log(msg) print(LOG_PREFIX .. " " .. tostring(msg)) end
local function logErr(msg, err) warn(LOG_PREFIX .. " 🚨 КРИТИЧЕСКИЙ СБОЙ: " .. tostring(msg) .. " -> " .. tostring(err)) end

local function safe(label, fn, ...)
	local pack = {...}
	local ok, res = pcall(function() return fn(table.unpack(pack)) end)
	if not ok then logErr(label, res) end
	return ok, res
end

-- Функция безопасного сканирования каналов
local function getCanonicalRemote(name, className)
	local target = eventsModule:FindFirstChild(name)
	if target and target.ClassName ~= className then
		target:Destroy()
		target = nil
	end
	if not target then
		target = Instance.new(className)
		target.Name = name
		target.Parent = eventsModule
	end
	return target
end

