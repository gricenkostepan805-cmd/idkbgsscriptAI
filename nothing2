-- 5. МАГАЗИНЫ НАПРЯМУЮ ЧЕРЕЗ BUYITEM (СПАВН ШMОТOК ЧЕРЕЗ КАНAЛЫ ОНЕТТА)
eventsModule.BuyItem.OnServerInvoke = function(p, item, cat, amt)
	print("🛒 [Shop Direct] Игрок " .. p.Name .. " покупает: " .. tostring(item) .. " (" .. tostring(cat) .. ")")
	local pData = cache[p]
	if not pData or type(pData) == "boolean" then return false end

	if cat == "Tools" or cat == "Collectors" then
		pData.EquippedCollector = item
		if pData.Gear then pData.Gear.Tool = item end

		pcall(function() 
			eventsModule.EquipCollector:FireClient(p, item) 
			eventsModule.ServerItemPackEvent:FireClient(p, "Update", {Type = "Collector", Item = item})
		end)
		return true 
	end

	if cat == "Backpacks" or cat == "Bags" then
		pData.EquippedBackpack = item
		if pData.Gear then pData.Gear.Backpack = item end

		pcall(function() 
			eventsModule.EquipBackpack:FireClient(p, item) 
			eventsModule.ServerItemPackEvent:FireClient(p, "Update", {Type = "Backpack", Item = item})
		end)
		return true 
	end

	if item == "BasicEgg" or item == "Basic Egg" or cat == "Eggs" then
		pData.Eggs = pData.Eggs or {} 
		pData.Eggs["BasicEgg"] = (pData.Eggs["BasicEgg"] or 0) + 1
		pcall(function() 
			eventsModule.ServerItemPackEvent:FireClient(p, "Give", {Category = "Eggs", Item = "BasicEgg", Amount = 1}) 
		end)
		return true
	end

	return false 
end

-- 6. HIVE CLAIMING via ClaimHive RemoteFunction
eventsModule.ClaimHive.OnServerInvoke = function(p, hid)
	if not hid then hid = 1 end
	log("ClaimHive from " .. p.Name .. " for HiveID=" .. tostring(hid))

	-- Check if this hive is already claimed by another player
	for otherPlayer, id in pairs(hivesCache) do
		if id == hid and otherPlayer ~= p then return false end
	end

	-- Ensure player has stats
	if not cache[p] or type(cache[p]) == "boolean" then
		cache[p] = {
			Honey = 10000, Capacity = 200, Pollen = 0, Tickets = 0, TotalHoney = 10000, DailyHoney = 10000,
			Gear = { Tool = "Scooper", Backpack = "Pouch" }, EquippedCollector = "Scooper", EquippedBackpack = "Pouch",
			Eggs = { ["BasicEgg"] = 1, ["Basic Egg"] = 1 },
			Bees = {}, Quests = { Active = {}, Completed = {} },
			Stickers = { BookSize = 16, Book = {}, Inbox = {} },
			Totals = { Stickers = { AnyCreated = 0, AnyReceived = 0, AnyTraded = 0, AddedToInbox = 0, HiddenFound = {}, Received = {}, Traded = {}, Discarded = {}, PutOnBoard = {} } },
			Amulets = {}, Beequips = {}
		}
	end
	local pData = cache[p]
	pData.HiveSlot = hid

	-- Find the matching Honeycomb model by checking HiveID on the Honeycomb model
	-- The platform's Hive ObjectValue points to a Honeycomb model in Workspace.Honeycombs
	-- The Honeycomb model has a HiveID IntValue that matches the hid parameter
	local honeycombModel = nil
	local matchedPlatform = nil
	local platforms = workspace:FindFirstChild("HivePlatforms")
	if platforms then
		for _, platform in ipairs(platforms:GetChildren()) do
			if platform:IsA("Model") then
				local hiveObj = platform:FindFirstChild("Hive")
				if hiveObj and hiveObj:IsA("ObjectValue") and hiveObj.Value then
					local honeycomb = hiveObj.Value
					local hiveIdObj = honeycomb:FindFirstChild("HiveID")
					if hiveIdObj and hiveIdObj.Value == hid then
						honeycombModel = honeycomb
						matchedPlatform = platform
						break
					end
				end
			end
		end
	end

	if not honeycombModel then
		warn("[Hive] Could not find Honeycomb model for HiveID=" .. tostring(hid))
		return false
	end

	log("Found Honeycomb model: " .. honeycombModel.Name .. " for HiveID=" .. tostring(hid))

	-- Set the Owner on the Honeycomb model
	local owner = honeycombModel:FindFirstChild("Owner")
	if owner and owner:IsA("ObjectValue") then
		owner.Value = p
	end

	-- Set Phase to "Beeless" (player has no bees yet)
	local phase = honeycombModel:FindFirstChild("Phase")
	if phase and phase:IsA("StringValue") then
		phase.Value = "Beeless"
	end

	-- Set PlayerRef on the platform to show it's claimed
	local playerRef = matchedPlatform:FindFirstChild("PlayerRef")
	if playerRef and playerRef:IsA("ObjectValue") then
		playerRef.Value = p
	end

	-- Create/set "Honeycomb" ObjectValue on the PLAYER (not the platform)
	-- This is what Activatables.Hives.hivePhase() checks: p1:FindFirstChild("Honeycomb")
	local playerHoneycomb = p:FindFirstChild("Honeycomb")
	if not playerHoneycomb then
		playerHoneycomb = Instance.new("ObjectValue")
		playerHoneycomb.Name = "Honeycomb"
		playerHoneycomb.Parent = p
	end
	playerHoneycomb.Value = honeycombModel

	-- Store honeycomb data in cache
	pData.Honeycomb = pData.Honeycomb or {}
	pData.Honeycomb.Owner = p.Name
	pData.Honeycomb.HiveId = hid
	pData.Honeycomb.Bees = pData.Honeycomb.Bees or {}
	if #pData.Honeycomb.Bees == 0 then
		table.insert(pData.Honeycomb.Bees, { Slot = 1, Type = "Basic", Level = 1, Style = "Normal" })
	end

	hivesCache[p] = hid

	-- Delegate to HoneycombManager if available
	if HM and HM.ClaimHive then
		pcall(function() HM.ClaimHive(p, hid) end)
	end

	-- Equip tools and backpack on the player's character
	pcall(function()
		if PlayerTools and PlayerTools.new then
			if not playerObjects[p] then
				playerObjects[p] = PlayerTools.new(p)
			end
			playerObjects[p]:EquipGear()
		end
	end)

	-- Fire events to clients
	pcall(function()
		eventsModule.HiveClaimed:FireAllClients(p, hid)
		eventsModule.UpdateHive:FireAllClients(hid, pData.Honeycomb)
		eventsModule.ServerItemPackEvent:FireClient(p, "HiveInitReady", {HiveId = hid, Data = pData.Honeycomb})
	end)

	return true
end

-- 7. QUEST COMPLETION via CompleteQuest RemoteEvent
eventsModule.CompleteQuest.OnServerEvent:Connect(function(p, questName)
	log("CompleteQuest from " .. p.Name .. " for quest: " .. tostring(questName))

	local stats = nil
	if PlayerStatManager and PlayerStatManager.GetStats then
		stats = PlayerStatManager.GetStats(p)
	end
	if not stats or not stats.Quests then return end

	local Quests = require(game.ReplicatedStorage.Quests)
	local quest = Quests:Get(questName)
	if not quest then
		warn("[Quest] Unknown quest: " .. tostring(questName))
		return
	end

	-- Check if quest is active; if not, auto-activate it (player accepting from NPC)
	local activeData = Quests:GetActiveData(questName, stats)
	if not activeData then
		local activated = false
		pcall(function() activated = Quests:Activate(questName, stats, true) end)
		if activated then
			log("Quest auto-activated: " .. tostring(questName) .. " for " .. p.Name)
			pcall(function()
				eventsModule.ServerQuestEvent:FireClient(p, "Activate", {questName}, stats.Quests)
			end)
		end
		return
	end

	-- Check if quest can be completed
	local canComplete = false
	pcall(function() canComplete = Quests:CanComplete(questName, stats) end)
	if not canComplete then
		warn("[Quest] Quest cannot be completed yet: " .. tostring(questName))
		return
	end

	-- Mark as completed: remove from Active, add to Completed
	for i, v in ipairs(stats.Quests.Active) do
		if v.Name == questName then
			table.remove(stats.Quests.Active, i)
			break
		end
	end
	table.insert(stats.Quests.Completed, questName)

	-- Give rewards
	local rewards = {}
	if quest.Rewards then
		for _, reward in ipairs(quest.Rewards) do
			if reward.Category == "Honey" then
				stats.Honey = (stats.Honey or 0) + (reward.Amount or 0)
			elseif reward.Category == "Eggs" then
				if not stats.Eggs then stats.Eggs = {} end
				if reward.Type then
					stats.Eggs[reward.Type] = (stats.Eggs[reward.Type] or 0) + (reward.Amount or 1)
				end
			end
			table.insert(rewards, reward)
		end
	end

	-- Fire ServerQuestEvent to client
	-- QuestListener expects: (action, questNames, questsTable, poolCounts, rewards)
	pcall(function()
		eventsModule.ServerQuestEvent:FireClient(p, "Complete", {questName}, stats.Quests, nil, rewards)
	end)

	log("Quest completed: " .. tostring(questName) .. " for " .. p.Name)
end)

-- 7b. QUEST COMPLETION FROM POOL via CompleteQuestFromPool RemoteEvent
eventsModule.CompleteQuestFromPool.OnServerEvent:Connect(function(p, poolName)
	log("CompleteQuestFromPool from " .. p.Name .. " for pool: " .. tostring(poolName))

	local stats = nil
	if PlayerStatManager and PlayerStatManager.GetStats then
		stats = PlayerStatManager.GetStats(p)
	end
	if not stats or not stats.Quests then return end

	local Quests = require(game.ReplicatedStorage.Quests)

	-- Find the active repeatable quest from this pool
	local activeQuest = Quests:GetActiveRepeatable(poolName, stats)
	if not activeQuest then
		-- Try to give a quest from this pool (player accepting from NPC)
		local gaveQuest, questId, givenQuestName = false, nil, nil
		pcall(function() gaveQuest, questId, givenQuestName = Quests:GiveQuestFromPool(poolName, stats) end)
		if gaveQuest and givenQuestName then
			log("Quest from pool given: " .. tostring(givenQuestName) .. " from pool " .. tostring(poolName) .. " for " .. p.Name)
			pcall(function()
				eventsModule.ServerQuestEvent:FireClient(p, "Activate", {givenQuestName}, stats.Quests, poolName)
			end)
		end
		return
	end

	local questName = activeQuest.Name
	local quest = Quests:Get(questName)
	if not quest then return end

	-- Check if quest can be completed
	local canComplete = false
	pcall(function() canComplete = Quests:CanComplete(questName, stats) end)
	if not canComplete then return end

	-- Mark as completed
	for i, v in ipairs(stats.Quests.Active) do
		if v.Name == questName then
			table.remove(stats.Quests.Active, i)
			break
		end
	end
	table.insert(stats.Quests.Completed, questName)

	-- Give rewards
	local rewards = {}
	if quest.Rewards then
		for _, reward in ipairs(quest.Rewards) do
			if reward.Category == "Honey" then
				stats.Honey = (stats.Honey or 0) + (reward.Amount or 0)
			elseif reward.Category == "Eggs" then
				if not stats.Eggs then stats.Eggs = {} end
				if reward.Type then
					stats.Eggs[reward.Type] = (stats.Eggs[reward.Type] or 0) + (reward.Amount or 1)
				end
			end
			table.insert(rewards, reward)
		end
	end

	-- Fire ServerQuestEvent to client
	pcall(function()
		eventsModule.ServerQuestEvent:FireClient(p, "Complete", {questName}, stats.Quests, nil, rewards)
	end)

	log("Pool quest completed: " .. tostring(questName) .. " for " .. p.Name)
end)

