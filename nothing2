			if plr:FindFirstChild("CoreStats") then
				if plr.CoreStats:FindFirstChild("Honey") then plr.CoreStats.Honey.Value = bd.Honey end
if plr.CoreStats:FindFirstChild("Capacity") then plr.CoreStats.Capacity.Value = bd.Capacity end
