-- ============================================================
-- CORE STATS: Create and sync NumberValues on the player object
-- ============================================================

local function ensureCoreStats(player)
	local coreStats = player:FindFirstChild("CoreStats")
	if not coreStats then
		coreStats = Instance.new("Folder")
		coreStats.Name = "CoreStats"
		coreStats.Parent = player
	end
	local statNames = { "Honey", "Pollen", "Capacity", "TotalHoney", "DailyHoney", "Tickets" }
	for _, name in ipairs(statNames) do
		local val = coreStats:FindFirstChild(name)
		if not val then
			val = Instance.new("NumberValue")
			val.Name = name
			val.Parent = coreStats
		end
	end
	return coreStats
end

local function syncCoreStats(player, stats)
	if not stats then return end
	local coreStats = ensureCoreStats(player)

	local honeyVal = coreStats:FindFirstChild("Honey")
	if honeyVal then honeyVal.Value = math.floor(stats.Honey or 0) end

	local pollenVal = coreStats:FindFirstChild("Pollen")
	if pollenVal then pollenVal.Value = stats.Pollen or 0 end

	local capacityVal = coreStats:FindFirstChild("Capacity")
	if capacityVal then
		local equippedBP = stats.EquippedBackpack or "Pouch"
		local cap = Backpacks.GetStat(equippedBP, "Capacity") or 200
		capacityVal.Value = cap
	end

	local totalHoneyVal = coreStats:FindFirstChild("TotalHoney")
	if totalHoneyVal then totalHoneyVal.Value = math.floor(stats.TotalHoney or stats.Honey or 0) end

	local dailyHoneyVal = coreStats:FindFirstChild("DailyHoney")
	if dailyHoneyVal then dailyHoneyVal.Value = math.floor(stats.DailyHoney or stats.Honey or 0) end

	local ticketsVal = coreStats:FindFirstChild("Tickets")
	if ticketsVal then ticketsVal.Value = stats.Tickets or 0 end
end

-- ============================================================
-- GEAR EQUIPMENT
-- ============================================================

local function equipCharacter(player, character)
	local humanoid = character:WaitForChild("Humanoid", 5)
	if not humanoid then return end

	-- Create OOP player object if not yet created
	if not activePlayerObjects[player] then
		local success, err = pcall(function()
			activePlayerObjects[player] = PlayerTools.new(player)
		end)
		if not success then
			warn("[MainServer] Failed to create PlayerTools object: " .. tostring(err))
		end
	end

	if activePlayerObjects[player] then
		pcall(function()
			activePlayerObjects[player]:EquipGear()
		end)
	end

	-- Sync CoreStats after character loads
	local stats = playerCache[player]
	if stats then
		syncCoreStats(player, stats)
	end
end

-- ============================================================
-- PLAYER ADD / REMOVE
-- ============================================================

local function onPlayerAdded(player)
	-- 1. Load player data from DataStore
	local _, baseData = DataStoreModule.Load("BSS_Alpha_Save_v1", player.UserId)
	if not baseData then
		baseData = DataStoreModule.NewPlayerData()
	end
	playerCache[player] = baseData

	-- 2. Sync gear stats (sets EquippedBackpack, EquippedCollector, Collectors, Backpacks arrays)
	pcall(function() Collectors.SyncStats(baseData) end)
	pcall(function() Backpacks.SyncStats(baseData) end)

	-- 3. Register with PlayerStatManager so PlayerTools.GetStats works
	PlayerStatManager.SetStats(player, baseData)

	-- 4. Create CoreStats folder IMMEDIATELY before character loads
	--    This eliminates infinite yield on WaitForChild("CoreStats") in MeterHUDInit
	syncCoreStats(player, baseData)

	-- 5. Handle character (may already exist in Studio play mode)
	if player.Character then
		task.spawn(function()
			task.wait(0.5)
			if player.Character then
				equipCharacter(player, player.Character)
			end
		end)
	end

	player.CharacterAdded:Connect(function(character)
		equipCharacter(player, character)
	end)

	-- 6. Trigger client stat cache reset so UI shows starter inventory
	pcall(function()
		local serverSystemEvent = ReplicatedStorage.Events:FindFirstChild("ServerSystemEvent")
		if serverSystemEvent then
			serverSystemEvent:FireClient(player, "FullCacheReset")
		end
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Handle players already in the game (Studio play mode edge case)
for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(function()
		onPlayerAdded(player)
	end)
end

