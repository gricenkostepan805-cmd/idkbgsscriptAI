		end)
		print("🚀 [MainServer Core] Package sent for " .. plr.Name)
	end)
	-- =========================================================================
	-- Изолированно в фоне тянем DataStore без блокировки основного потока
	task.spawn(function()
		local ok, res = pcall(function() 
			if DS and DS.Load then return DS.Load("BSS_Alpha_Save_v3", plr.UserId) end
