	baseData.EquippedCollector = nil
	baseData.EquippedBackpack = nil
	baseData.Eggs = { ["BasicEgg"] = 1, ["Basic Egg"] = 1 }
	playerCache[player] = baseData

	-- leaderstats для правого списка игроков
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats" 
	leaderstats.Parent = player

	local honeyVal = Instance.new("NumberValue") 
	honeyVal.Name = "Honey" 
	honeyVal.Value = 0 
	honeyVal.Parent = leaderstats
	-- Запускаем ООП-механику шмоток Онетта
	pcall(function() activePlayerObjects[player] = PlayerTools.new(player) end)

	-- МОНТИРУЕМ ПАПКИ И РЕШЁТКИ В МОМЕНТ СПАВНА ПЕРСОНАЖА (СТРОГО ПО СКРИНШОТУ DEX)
