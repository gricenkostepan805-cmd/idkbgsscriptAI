		print("📦 [DEX ENGINE] Монтируем анатомию игрока строго по скриншоту...")

		local coreStats = player:FindFirstChild("CoreStats") or Instance.new("Folder")
		coreStats.Name = "CoreStats"
		coreStats.Parent = player

		-- Насыщаем NumberValue-решётками (#) строго внутрь CoreStats
		local statsToCreate = {
			{"Capacity", 200},
			{"Honey", 0},
			{"Pollen", 0}
		}
		for _, data in ipairs(statsToCreate) do
			local val = coreStats:FindFirstChild(data[1]) or Instance.new("NumberValue")
			val.Name = data[1] -- Пофиксили индексы data[1] намертво! 😎🔥
			val.Value = data[2]
			val.Parent = coreStats
		end

		local tradeConfig = player:FindFirstChild("TradeConfig") or Instance.new("Folder")
		tradeConfig.Name = "TradeConfig"
		tradeConfig.Parent = player

		local tradeFlags = {
			{"CanTrade", true},
			{"IsTrading", false},
			{"RequestsEnabled", true}
		}
		for _, flag in ipairs(tradeFlags) do
			local boolVal = tradeConfig:FindFirstChild(flag[1]) or Instance.new("BoolValue")
			boolVal.Name = flag[1] -- Пофиксили индексы flag[1] намертво!
			boolVal.Value = flag[2]
			boolVal.Parent = tradeConfig
		end

		if not player:FindFirstChild("ActivatableTarget") then
			local targetVal = Instance.new("ObjectValue")
			targetVal.Name = "ActivatableTarget"
			targetVal.Parent = player
		end

		local spawnVal = player:FindFirstChild("SpawnPos") or Instance.new("Vector3Value")
		spawnVal.Name = "SpawnPos"
		spawnVal.Value = character:GetPivot().Position
		spawnVal.Parent = player

		task.wait(1.5)

		-- Синхронизируем базовые листенеры заставки
		pcall(function()
			ServerItemPackEvent:FireClient(player, "Give", {Category = "Eggs", Item = "BasicEgg", Amount = 1})
			ServerItemPackEvent:FireClient(player, "SetupListenersReady", {Ready = true})
			ServerItemPackEvent:FireClient(player, "ReplicationReady", {Ready = true})
		end)
	end)
end)
