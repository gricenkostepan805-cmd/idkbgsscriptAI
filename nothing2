-- АВТОРИТЕТНЫЙ СБОР ПЫЛЬЦЫ С ОГРАНИЧЕНИЕМ CAPACITY РЮКЗАКА
ToolCollect.OnServerEvent:Connect(function(player, ...)
	local collectArgs = {...}
	if PollenTools and PollenTools.CollectPollen then pcall(function() PollenTools.CollectPollen(player, table.unpack(collectArgs)) end) end

	local pData = playerCache[player]
	if pData and player:FindFirstChild("CoreStats") then
		local currentCapacity = player.CoreStats:FindFirstChild("Capacity") and player.CoreStats.Capacity.Value or 200
		pData.Pollen = math.min((pData.Pollen or 0) + 8, currentCapacity)

		if player.CoreStats:FindFirstChild("Pollen") then player.CoreStats.Pollen.Value = pData.Pollen end
		pcall(function() 
			ServerItemPackEvent:FireClient(player, "Update", {Pollen = pData.Pollen, Honey = pData.Honey})
			local FlowerRegen = eventsModule:FindFirstChild("FlowerRegen")
			if FlowerRegen then FlowerRegen:FireClient(player, table.unpack(collectArgs)) end
		end)
	end
end)

InteractNPC.OnServerEvent:Connect(function(player, npcName, actionType)
	local pData = playerCache[player]
	if pData then
		pData.NPCs = pData.NPCs or {} pData.NPCs[npcName] = pData.NPCs[npcName] or { Event = 1, Phase = "Start" }
		pData.NPCs[npcName].Event = pData.NPCs[npcName].Event + 1
		pData.Quests = pData.Quests or {} pData.Quests.Active = pData.Quests.Active or {}
		if not pData.Quests.Active[npcName] then
			pData.Quests.Active[npcName] = { Name = npcName .. "'s Starter Task", Progress = 0, Target = 200, Status = "Active" }
			pcall(function() ServerItemPackEvent:FireClient(player, "QuestUpdate", {NPC = npcName, QuestData = pData.Quests.Active[npcName]}) end)
		end
	end
end)

RequestConversionRf.OnServerInvoke = function(player)
	local pData = playerCache[player]
	if pData and pData.Pollen > 0 then
		local converted = pData.Pollen pData.Honey = pData.Honey + converted pData.Pollen = 0
		if player.CoreStats:FindFirstChild("Honey") then player.CoreStats.Honey.Value = pData.Honey end
		if player.CoreStats:FindFirstChild("Pollen") then player.CoreStats.Pollen.Value = 0 end
		if player.leaderstats:FindFirstChild("Honey") then player.leaderstats.Honey.Value = pData.Honey end
		pcall(function() ServerItemPackEvent:FireClient(player, "Update", {Pollen = 0, Honey = pData.Honey}) end)
		return true
	end
	return false
end

-- КАНOНИЧНЫЙ МАГАЗИН: ПОКУПКА С EMIT-СИГНАЛАМИ
BuyItemRf.OnServerInvoke = function(player, itemName, category, amount)
	print("🛒 [Магазин] Запрос покупки: " .. tostring(itemName) .. " из категории: " .. tostring(category))
	local pData = playerCache[player]
	if not pData then return false end

	if category == "Tools" or category == "Collectors" then
		pData.EquippedCollector = itemName
		pcall(function()
			eventsModule.EquipCollector:FireClient(player, itemName)
			ServerItemPackEvent:FireClient(player, "Update", {Honey = pData.Honey})
		end)
		return true
	end

	if category == "Backpacks" or category == "Bags" then
		pData.EquippedBackpack = itemName
		pcall(function()
			eventsModule.EquipBackpack:FireClient(player, itemName)
		end)
		return true
	end

	if itemName == "BasicEgg" or itemName == "Basic Egg" or category == "Eggs" then
		pData.Eggs = pData.Eggs or {} pData.Eggs["BasicEgg"] = (pData.Eggs["BasicEgg"] or 0) + 1
		pcall(function() ServerItemPackEvent:FireClient(player, "Give", {Category = "Eggs", Item = "BasicEgg", Amount = 1}) end)
		return true
	end
	return false
end

-- КАНOНИЧНЫЙ ДВИЖОК УЛЬЕВ HONEYCOMBS
ClaimHiveRf.OnServerInvoke = function(player, hiveId)
	if not hiveId then hiveId = 1 end
	print("🐝 [Server Hive] Запрос занятия улья ID: " .. tostring(hiveId) .. " от " .. player.Name)

	-- Защита от перехвата чужого улья
	for otherPlayer, id in pairs(hivesCache) do 
		if id == hiveId and otherPlayer ~= player then return false end 
	end

	local pData = playerCache[player]
	if pData then
		pData.Honeycomb = pData.Honeycomb or {}
		pData.Honeycomb.Owner = player.Name 
		pData.Honeycomb.HiveId = hiveId 
		pData.Honeycomb.Bees = pData.Honeycomb.Bees or {}

		if #pData.Honeycomb.Bees == 0 then 
			table.insert(pData.Honeycomb.Bees, { Slot = 1, Type = "Basic", Level = 1, Style = "Normal" }) 
		end

		hivesCache[player] = hiveId

		pcall(function()
			HiveClaimedRe:FireAllClients(player, hiveId)
			UpdateHiveRe:FireAllClients(hiveId, pData.Honeycomb)
		end)

		-- СИЛОВОЙ ЗЕРКАЛЬНЫЙ ВЫСТРЕЛ ПО ВЫДЕЛЕННЫМ КАНАЛАМ ОНЕТТА!
		task.wait(0.5)
		pcall(function()
			-- Так как в датасторе теперь лежит легальный чистый nil, клиентский скрипт 
			-- сам, дойдя до конца, выставит "Scooper" и "Pouch" по своим внутренним инитам!
			local currentTool = pData.EquippedCollector or "Scooper"
			local currentBackpack = pData.EquippedBackpack or "Pouch"

			eventsModule.EquipCollector:FireClient(player, currentTool)
			eventsModule.EquipBackpack:FireClient(player, currentBackpack)

			ServerItemPackEvent:FireClient(player, "HiveInitReady", {HiveId = hiveId, Data = pData.Honeycomb})
		end)
		return true
	end
	return false
end

Players.PlayerRemoving:Connect(function(player)
	local pData = playerCache[player]
	if pData then pcall(function() DataStoreModule.WaitUntilSave("BSS_Alpha_Save_v3", player.UserId, pData) end) end
	if hivesCache[player] then local id = hivesCache[player] hivesCache[player] = nil pcall(function() UpdateHiveRe:FireAllClients(id, {Owner = nil, Bees = {}}) end) end
	playerCache[player] = nil
	if activePlayerObjects[player] then pcall(function() activePlayerObjects[player]:Destroy() end) activePlayerObjects[player] = nil end
end)

