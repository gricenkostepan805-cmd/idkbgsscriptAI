-- PlayerTools: Server-side player utility functions
-- Required by TeleportManager, ClassicMinigame scripts, Toys, etc.
-- Provides GetStats, IsLoaded, SetFlag, CheckReqs, CountBees, etc.

local PlayerTools = {}

local PlayerStatManager = require(script.Parent.PlayerStatManager)
local StatTools = require(game.ReplicatedStorage.StatTools)
local HoneycombFileTools = require(game.ReplicatedStorage.HoneycombFileTools)

function PlayerTools.GetStats(player)
	return PlayerStatManager.GetStats(player)
end

function PlayerTools.IsLoaded(player)
	local stats = PlayerStatManager.GetStats(player)
	return stats ~= nil
end

function PlayerTools.SetFlag(player, flagName, isServerSide)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		StatTools.SetFlag(stats, flagName, isServerSide)
	end
end

function PlayerTools.RemoveFlag(player, flagName, isServerSide)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		StatTools.RemoveFlag(stats, flagName, isServerSide)
	end
end

function PlayerTools.HasFlag(player, flagName, isServerSide)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return StatTools.HasFlag(stats, flagName, isServerSide)
	end
	return false
end

function PlayerTools.CheckReqs(player, reqs)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return StatTools.CheckReqs(stats, reqs)
	end
	return false
end

function PlayerTools.CountBees(player, filter)
	local stats = PlayerStatManager.GetStats(player)
	if stats and stats.Honeycomb then
		return HoneycombFileTools.Count(stats.Honeycomb, filter)
	end
	return 0
end

function PlayerTools.CheckIfRoboBearChallengeRoundIsRunning(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return StatTools.CheckIfRoboBearChallengeRoundIsRunning(stats)
	end
	return false
end

function PlayerTools.CheckIfRoboBearChallengeIsActive(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return StatTools.CheckIfRoboBearChallengeIsActive(stats)
	end
	return false
end

function PlayerTools.GetHoney(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return stats.Honey or 0
	end
	return 0
end

function PlayerTools.SetHoney(player, amount)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		stats.Honey = amount
	end
end

function PlayerTools.AddHoney(player, amount)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		stats.Honey = (stats.Honey or 0) + amount
	end
end

function PlayerTools.GetEggs(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return stats.Eggs or {}
	end
	return {}
end

function PlayerTools.GetHoneycomb(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return stats.Honeycomb
	end
	return nil
end

function PlayerTools.GetTotals(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return stats.Totals
	end
	return nil
end

function PlayerTools.GetSettings(player)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		return stats.Settings or {}
	end
	return {}
end

function PlayerTools.SetSetting(player, key, value)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		if not stats.Settings then
			stats.Settings = {}
		end
		stats.Settings[key] = value
	end
end

-- ============================================================
-- ITEM MANAGEMENT
-- ============================================================

function PlayerTools.TakeItems(player, itemsTable)
	-- Remove items from the player's inventory
	-- itemsTable is an array of {Category, Type, Amount} entries
	local stats = PlayerStatManager.GetStats(player)
	if not stats then return false end

	for _, item in ipairs(itemsTable or {}) do
		if item.Category == "Honey" then
			stats.Honey = math.max(0, (stats.Honey or 0) - (item.Amount or 0))
		elseif item.Category == "Eggs" then
			if stats.Eggs and item.Type then
				stats.Eggs[item.Type] = math.max(0, (stats.Eggs[item.Type] or 0) - (item.Amount or 0))
				if stats.Eggs[item.Type] <= 0 then
					stats.Eggs[item.Type] = nil
				end
			end
		elseif item.Category == "Items" then
			if stats.Items and item.Type then
				local current = stats.Items[item.Type]
				if type(current) == "number" then
					stats.Items[item.Type] = math.max(0, current - (item.Amount or 1))
					if stats.Items[item.Type] <= 0 then
						stats.Items[item.Type] = nil
					end
				elseif current ~= nil then
					stats.Items[item.Type] = nil
				end
			end
		end
	end
	return true
end

function PlayerTools.TakeItem(player, itemTable)
	-- Remove a single item from the player
	return PlayerTools.TakeItems(player, { itemTable })
end

function PlayerTools.GiveItems(player, itemsTable)
	-- Give items to the player
	local stats = PlayerStatManager.GetStats(player)
	if not stats then return false end

	for _, item in ipairs(itemsTable or {}) do
		if item.Category == "Honey" then
			stats.Honey = (stats.Honey or 0) + (item.Amount or 0)
		elseif item.Category == "Eggs" then
			if not stats.Eggs then stats.Eggs = {} end
			if item.Type then
				stats.Eggs[item.Type] = (stats.Eggs[item.Type] or 0) + (item.Amount or 0)
			end
		elseif item.Category == "Items" then
			if not stats.Items then stats.Items = {} end
			if item.Type then
				local current = stats.Items[item.Type]
				if type(current) == "number" then
					stats.Items[item.Type] = current + (item.Amount or 1)
				else
					stats.Items[item.Type] = item.Amount or true
				end
			end
		elseif item.Category == "Bundle" then
			if not stats.Totals then stats.Totals = {} end
			if not stats.Totals.Bundles then stats.Totals.Bundles = {} end
		end
	end
	return true
end

-- ============================================================
-- ALERTS & MESSAGING
-- ============================================================

function PlayerTools.Alert(player, message, color)
	-- Send an alert message to a specific player
	local Events = require(game.ReplicatedStorage.Events)
	Events.ServerCall("ReceiveAlert", player, message, color)
end

function PlayerTools.AlertAll(message, color)
	-- Send an alert message to all players
	local Events = require(game.ReplicatedStorage.Events)
	Events.ServerCallToAll("ReceiveAlert", message, color)
end

-- ============================================================
-- CACHE MANAGEMENT
-- ============================================================

function PlayerTools.CacheResetStat(player, statName)
	-- Mark a specific stat as needing refresh on client
	-- In the original game, this triggers a client stat cache reset for the given stat
	local Events = require(game.ReplicatedStorage.Events)
	local stats = PlayerStatManager.GetStats(player)
	if stats then
		Events.ServerCall("QuestsChanged", player, statName)
	end
end

function PlayerTools.CacheReset(player, statPath)
	-- Reset the client's cached stat for the given path
	-- statPath can be a string or table path
	local Events = require(game.ReplicatedStorage.Events)
	if type(statPath) == "string" then
		Events.ServerCall("QuestsChanged", player, statPath)
	elseif type(statPath) == "table" then
		Events.ServerCall("QuestsChanged", player, statPath)
	end
end

-- ============================================================
-- POSITION & ZONE UTILITIES
-- ============================================================

function PlayerTools.GetCFrame(player)
	-- Get the player's current world position as a CFrame
	local character = player.Character
	if character then
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		if rootPart then
			return rootPart.CFrame
		end
	end
	return CFrame.new(0, 5, 0)
end

function PlayerTools.PlayerToFlowerZone(player)
	-- Determine which flower field zone the player is in
	local cframe = PlayerTools.GetCFrame(player)
	local position = cframe.Position

	-- Check against known field positions
	-- This is a simplified version - the original uses field boundary detection
	local fields = {
		{ Name = "Sunflower", X = -80, Z = 30, Radius = 60 },
		{ Name = "Dandelion", X = -100, Z = 100, Radius = 50 },
		{ Name = "Mushroom", X = -100, Z = -50, Radius = 50 },
		{ Name = "Blue Flower", X = 100, Z = 70, Radius = 50 },
		{ Name = "Clover", X = -150, Z = 50, Radius = 60 },
		{ Name = "Spider", X = -50, Z = -100, Radius = 50 },
		{ Name = "Bamboo", X = 50, Z = -100, Radius = 50 },
		{ Name = "Strawberry", X = -150, Z = -80, Radius = 50 },
		{ Name = "Pineapple", X = 100, Z = -150, Radius = 50 },
		{ Name = "Cactus", X = 150, Z = -100, Radius = 60 },
		{ Name = "Pumpkin", X = -200, Z = -150, Radius = 50 },
		{ Name = "Pine Tree", X = -50, Z = -200, Radius = 50 },
		{ Name = "Rose", X = 200, Z = -200, Radius = 50 },
		{ Name = "Mountain Top", X = 0, Z = -300, Radius = 50 },
		{ Name = "Stump", X = 250, Z = 100, Radius = 50 },
		{ Name = "Pepper", X = 200, Z = 200, Radius = 50 },
	}

	for _, field in ipairs(fields) do
		local dist = math.sqrt((position.X - field.X)^2 + (position.Z - field.Z)^2)
		if dist < field.Radius then
			return field.Name
		end
	end

	return nil
end

-- ============================================================
-- PLAYER STATE CHECKS
-- ============================================================

function PlayerTools.IsActive(player)
	-- Check if the player is active (loaded and in game)
	if not player then return false end
	local stats = PlayerStatManager.GetStats(player)
	return stats ~= nil
end

function PlayerTools.IsInGame(player)
	-- Check if the player is currently in the game world
	return PlayerTools.IsActive(player)
end

return PlayerTools
