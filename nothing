rfHandlers.RetrievePlayerStatsSummary = function(player)
	local stats = getPlayerData(player)
	if not stats then return nil end
	return { Honey = stats.Honey or 0, BeeCount = HoneycombFileTools.Count(stats.Honeycomb), QuestCount = stats.Quests and #stats.Quests or 0 }
end

rfHandlers.RetrieveBeeInfoSummary = function(player)
	local stats = getPlayerData(player)
	if not stats or not stats.Honeycomb then return {} end
	local summary = {}
	HoneycombFileTools.ForEachBee(stats.Honeycomb, function(beeFile)
		if beeFile and beeFile.Type then table.insert(summary, { Type = beeFile.Type, Level = beeFile.Lvl or 1 }) end
	end)
	return summary
end

rfHandlers.ConstructHiveCellFromEgg = function(player, eggType, slotX, slotY)
	local stats = getPlayerData(player)
	if not stats then return false, "Player data not loaded" end
	if not stats.Eggs then stats.Eggs = {} end
	local eggCount = stats.Eggs[eggType] or 0
	if eggCount <= 0 then return false, "No egg of this type" end
	if not stats.Honeycomb then stats.Honeycomb = {} end
	local xKey, yKey = "x" .. slotX, "y" .. slotY
	if not stats.Honeycomb[xKey] then stats.Honeycomb[xKey] = {} end
	if stats.Honeycomb[xKey][yKey] then return false, "Slot already occupied" end
	local beeTypeName = string.gsub(eggType, "Egg$", "")
	beeTypeName = string.gsub(beeTypeName, "Bee$", "")
	beeTypeName = string.gsub(beeTypeName, "Jelly$", "")
	local beeTypeData = BeeTypes:Get(beeTypeName)
	if not beeTypeData then
		beeTypeData = BeeTypes:Get(beeTypeName .. "Bee")
		if beeTypeData then beeTypeName = beeTypeName .. "Bee" end
	end
	if not beeTypeData then return false, "Unknown bee type from egg: " .. eggType end
	local beeFile = createDefaultBeeFile(beeTypeName)
	if not beeFile then return false, "Failed to create bee" end
	stats.Honeycomb[xKey][yKey] = beeFile
	stats.Eggs[eggType] = eggCount - 1
	if stats.Eggs[eggType] <= 0 then stats.Eggs[eggType] = nil end
	if beeTypeData.ID then
		local found = false
		for _, id in ipairs(stats.DiscoveredBees or {}) do
			if id == beeTypeData.ID then found = true; break end
		end
		if not found then
			if not stats.DiscoveredBees then stats.DiscoveredBees = {} end
			table.insert(stats.DiscoveredBees, beeTypeData.ID)
		end
	end
	dirtyPlayers[player.UserId] = true
	return true, beeFile
end

rfHandlers.GetBondToLevel = function(player, level) return BeeStats.LvlToTotalBond(level) end
