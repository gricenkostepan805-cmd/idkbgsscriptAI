-- ToolCollect: Pollen collection when player swings their tool
Events.ServerListen("ToolCollect", function(player, ...)
	pcall(function(...)
		PollenTools.CollectPollen(player, ...)
	end, ...)

	-- Sync CoreStats values
	local pData = playerCache[player]
	if pData then
		PollenTools.SyncCoreStats(player)
	end
end)

-- ClientSetUpListeners: Client signals it's ready for server-to-client events
Events.ServerListen("ClientSetUpListeners", function(player)
	print("[SERVER] " .. player.Name .. " has set up listeners")
	-- Fire initial data to the client
	pcall(function()
		Events.ServerCall("ServerItemPackEvent", player, "Init", { Ready = true })
	end)
end)

-- ClaimHive: Player claims a hive
Events.ServerListen("ClaimHive", function(player, hiveId)
	print("[SERVER] " .. player.Name .. " claimed hive " .. tostring(hiveId))
	local pData = playerCache[player]
	if pData then
		pData.HiveSlot = hiveId or 1
		pData.Honeycomb = pData.Honeycomb or {}
		-- Ensure Honeycomb only contains nested bee tables, not metadata
		for k, v in pairs(pData.Honeycomb) do
			if type(v) ~= "table" then
				pData.Honeycomb[k] = nil
			end
		end
	end
end)

-- PlayerHiveCommand: Hive commands (spawn bee, etc.)
Events.ServerListen("PlayerHiveCommand", function(player, command, ...)
	local pData = playerCache[player]
	if not pData then return end
	-- Handle various hive commands
	if command == "SpawnBee" then
		if not pData.Bees then pData.Bees = {} end
		if #pData.Bees < 25 then
			table.insert(pData.Bees, { Type = "Basic", Level = 1 })
		end
	end
end)

-- SelectNPCOption: Player selects an NPC dialog option
Events.ServerListen("SelectNPCOption", function(player, npcName, optionIndex)
	local pData = playerCache[player]
	if pData and pData.NPCs and pData.NPCs[npcName] then
		pData.NPCs[npcName].Event = (pData.NPCs[npcName].Event or 1) + 1
	end
end)

