rfHandlers.ItemPackageEvent = function(player, action, ...)
	local args = { ... }
	local stats = getPlayerData(player)
	if action == "Has" then return stats and stats.Items and stats.Items[args[1]] ~= nil or false
	elseif action == "Take" then
		if stats and stats.Items and stats.Items[args[1]] then stats.Items[args[1]] = nil; dirtyPlayers[player.UserId] = true; return true end
		return false
	elseif action == "Give" then
		if stats then if not stats.Items then stats.Items = {} end; stats.Items[args[1]] = args[2] or true; dirtyPlayers[player.UserId] = true; return true end
		return false
	end
	return nil
end

