-- ============================================================
-- PLAYER LIFECYCLE
-- ============================================================

local function setupLeaderstats(player)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local honeyStat = Instance.new("NumberValue")
	honeyStat.Name = "Honey"
	honeyStat.Value = 0
	honeyStat.Parent = leaderstats

	local pollenStat = Instance.new("NumberValue")
	pollenStat.Name = "Pollen"
	pollenStat.Value = 0
	pollenStat.Parent = leaderstats
end

local function onPlayerAdded(player)
	setupLeaderstats(player)
	initializePlayerData(player)
	PlayerStatManager.SetMainServer({ GetPlayerData = getPlayerData })

	local function onCharacterAdded(character)
		task.wait(1)
		giveStarterTools(player, character)
		syncCoreStats(player)
	end

	-- Handle case where character already exists (race condition fix)
	if player.Character then
		task.spawn(onCharacterAdded, player.Character)
	end
	player.CharacterAdded:Connect(onCharacterAdded)

	print("[MainServer] Player " .. player.Name .. " data initialized")
end
local function onPlayerRemoving(player)
	removePlayerData(player)
	PlayerSessionManager.RemovePlayer(player)
	for hivePart, ownerId in pairs(hiveOwnership) do
		if ownerId == player.UserId then hiveOwnership[hivePart] = nil end
	end
	print("[MainServer] Player " .. player.Name .. " data saved and cleaned up")
end

