local function createDefaultBeeFile(beeType)
	local typeData = BeeTypes:Get(beeType)
	if not typeData then return nil end
	return {
		Type = beeType,
		Birth = os.time(),
		Lvl = 1,
		Mood = 0.5,
		Bond = 0,
		Energy = BeeTypes:GetStat(beeType, "MaxEnergy") or 20,
		Traits = {},
		Equips = nil,
	}
end

local function createDefaultHoneycomb()
	local honeycomb = {}
	local basicBee = createDefaultBeeFile("Basic")
	if basicBee then
		honeycomb["x1"] = {}
		honeycomb["x1"]["y1"] = basicBee
	end
	return honeycomb
end

