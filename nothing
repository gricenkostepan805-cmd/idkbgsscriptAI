task.spawn(function()
	while task.wait(AUTO_SAVE_INTERVAL) do
		for userId, _ in pairs(dirtyPlayers) do
			if activePlayerData[userId] then
				savePlayerData(userId)
				local player = Players:GetPlayerByUserId(userId)
				if player then syncCoreStats(player) end
			end
		end
	end
end)

-- ============================================================
-- PERIODIC CORESTATS SYNC
-- ============================================================

task.spawn(function()
	while task.wait(5) do
		for _, player in ipairs(Players:GetPlayers()) do
			if activePlayerData[player.UserId] then
				syncCoreStats(player)
			end
		end
	end
end)

-- ============================================================
-- SERVER VERSION
-- ============================================================

local serverVersion = game.Workspace:FindFirstChild("ServerVersion")
if serverVersion and serverVersion:IsA("IntValue") then serverVersion.Value = 1 end

-- ============================================================
-- INITIALIZATION
-- ============================================================

registerHandlers()

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, player)
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

game:BindToClose(function()
	print("[MainServer] Server shutting down, saving all player data...")
	for userId, _ in pairs(activePlayerData) do savePlayerData(userId) end
	task.wait(2)
end)

print("[MainServer] Bee Swarm Simulator server initialized successfully")
print("[MainServer] DataStore " .. (dataStoreAvailable and "available" or "unavailable (Studio mode)"))
