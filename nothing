-- ============================================================
-- DATA STORE OPERATIONS
-- ============================================================

local function loadPlayerData(userId)
	if not dataStoreAvailable then return nil end
	local success, data = pcall(function()
		return playerDataStore:GetAsync("Player_" .. userId)
	end)
	if success and data then
		if type(data) == "string" then
			local ok, decoded = pcall(function() return HttpService:JSONDecode(data) end)
			if ok then return decoded end
		elseif type(data) == "table" then
			return data
		end
	end
	return nil
end

local function savePlayerData(userId)
	if not dataStoreAvailable then return end
	local stats = activePlayerData[userId]
	if not stats then return end
	local saveData = {}
	for k, v in pairs(stats) do
		if k ~= "ServerSide" then saveData[k] = v end
	end
	local success, err = pcall(function()
		playerDataStore:SetAsync("Player_" .. userId, saveData)
	end)
	if success then
		dirtyPlayers[userId] = nil
	else
		warn("Failed to save data for user " .. userId .. ": " .. tostring(err))
	end
end

-- ============================================================
-- PLAYER DATA MANAGEMENT
-- ============================================================

local function getPlayerData(player)
	return activePlayerData[player.UserId]
end

local function createCoreStats(player)
	local existing = player:FindFirstChild("CoreStats")
	if existing then existing:Destroy() end

	local coreStats = Instance.new("Folder")
	coreStats.Name = "CoreStats"
	coreStats.Parent = player

	local honeyVal = Instance.new("NumberValue")
	honeyVal.Name = "Honey"
	honeyVal.Value = 0
	honeyVal.Parent = coreStats

	local pollenVal = Instance.new("NumberValue")
	pollenVal.Name = "Pollen"
	pollenVal.Value = 0
	pollenVal.Parent = coreStats

	local capacityVal = Instance.new("NumberValue")
	capacityVal.Name = "Capacity"
	capacityVal.Value = 200
	capacityVal.Parent = coreStats

	return coreStats
end

local function syncCoreStats(player)
	local stats = getPlayerData(player)
	if not stats then return end

	local coreStats = player:FindFirstChild("CoreStats")
	if not coreStats then
		coreStats = createCoreStats(player)
	end

	local honeyVal = coreStats:FindFirstChild("Honey")
	if honeyVal then honeyVal.Value = math.floor(stats.Honey or 0) end

	local pollenVal = coreStats:FindFirstChild("Pollen")
	if pollenVal then pollenVal.Value = stats.Pollen or 0 end

	local capacityVal = coreStats:FindFirstChild("Capacity")
	if capacityVal then capacityVal.Value = PollenTools.GetCapacity(player) end
end

local function convertAccessoryToTool(accessory, name)
	local tool = Instance.new("Tool")
	tool.Name = name
	tool.RequiresHandle = true
	tool.CanBeDropped = false

	local children = accessory:GetChildren()
	for _, child in ipairs(children) do
		if child:IsA("Weld") then
			child.Parent = nil
		else
			child.Parent = tool
		end
	end

	local handle = tool:FindFirstChild("Handle")
	if handle then
		tool.Grip = handle.CFrame:Inverse()
	end

	accessory:Destroy()
	return tool
end

local function giveStarterTools(player, character)
	if not character then return end

	local stats = getPlayerData(player)
	if not stats then return end

	local equippedCollector = stats.EquippedCollector or "Scooper"
	local collectorData = Collectors.Get(equippedCollector)
	if collectorData and collectorData.Model then
		local model = collectorData.Model:Clone()
		model.Name = equippedCollector
		for _, part in model:GetDescendants() do
			if part:IsA("BasePart") then
				part.Anchored = false
			end
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			if model:IsA("Tool") then
				humanoid:EquipTool(model)
			elseif model:IsA("Accessory") then
				local tool = convertAccessoryToTool(model, equippedCollector)
				humanoid:EquipTool(tool)
			else
				model.Parent = character
			end
		end
	end

	local equippedBP = stats.EquippedBackpack or "Pouch"
	if equippedBP ~= "None" then
		local bpModel = Backpacks.Make(equippedBP)
		if bpModel and character then
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid:AddAccessory(bpModel)
			end
		end
	end
end

local function initializePlayerData(player)
	local userId = player.UserId
	local savedData = loadPlayerData(userId)
	local stats
	if savedData then
		stats = savedData
		if not stats.Honeycomb then stats.Honeycomb = createDefaultHoneycomb() end
		if not stats.Totals then stats.Totals = createDefaultPlayerData().Totals end
		if not stats.Eggs then stats.Eggs = {} end
		if not stats.Flags then stats.Flags = {} end
		if not stats.Settings then stats.Settings = {} end
		if not stats.Badges then stats.Badges = {} end
		if not stats.DiscoveredBees then stats.DiscoveredBees = { 1 } end
		if not stats.DiscGiftTypes then stats.DiscGiftTypes = {} end
		if not stats.Quests then stats.Quests = {} end
		if not stats.Items then stats.Items = {} end
		if not stats.Cubs then stats.Cubs = { TotalGiven = 0, Active = true, EquippedID = nil, Skins = {}, Files = {} } end
		if not stats.RoboChallenges then stats.RoboChallenges = {} end
		if not stats.SystemTimes then stats.SystemTimes = {} end
		if not stats.ServerSide then stats.ServerSide = { Flags = {}, SystemTimes = {}, IntervalBackups = {} } end
		if not stats.Totals.Pollen then stats.Totals.Pollen = { All = 0, Zones = {}, ZoneColors = {}, Colors = { White = 0, Red = 0, Blue = 0 }, ByTag = {} } end
		if not stats.Totals.Puffshrooms then stats.Totals.Puffshrooms = { Total = 0, ByLvl = {}, ByZone = {}, ByRarity = {} } end
		if not stats.Totals.ChallengePollen then stats.Totals.ChallengePollen = { All = 0, Zones = {}, ZoneColors = {}, Colors = { White = 0, Red = 0, Blue = 0 }, ByTag = {} } end
		if not stats.Totals.Honey then stats.Totals.Honey = 0 end
		if not stats.Pollen then stats.Pollen = 0 end
	else
		stats = createDefaultPlayerData()
	end

	Collectors.SyncStats(stats)
	Backpacks.SyncStats(stats)

	stats.LoadTime = os.time()
	if not stats.PlaytimeAtLoad then stats.PlaytimeAtLoad = 0 end
	activePlayerData[userId] = stats
	PlayerStatManager.SetStats(player, stats)
	dirtyPlayers[userId] = true

	createCoreStats(player)
	syncCoreStats(player)

	return stats
end

local function removePlayerData(player)
	local userId = player.UserId
	if activePlayerData[userId] then
		savePlayerData(userId)
		activePlayerData[userId] = nil
		dirtyPlayers[userId] = nil
	end
end

