reHandlers.PlayerSettingsEvent = function(player, key, value)
	local stats = getPlayerData(player)
	if stats then if not stats.Settings then stats.Settings = {} end; stats.Settings[key] = value; dirtyPlayers[player.UserId] = true end
end

reHandlers.ClaimHive = function(player, hivePart)
	if not hivePart or not hivePart:IsA("Instance") then return end
	if hiveOwnership[hivePart] then return end
	for _, ownerId in pairs(hiveOwnership) do if ownerId == player.UserId then return end end
	hiveOwnership[hivePart] = player.UserId
	local stats = getPlayerData(player)
	if stats then StatTools.SetFlag(stats, "HiveClaimed"); dirtyPlayers[player.UserId] = true end
	if stats and (stats.Pollen or 0) > 0 then
		local pollen = stats.Pollen
		stats.Honey = (stats.Honey or 0) + pollen
		stats.Pollen = 0
		if stats.Totals then
			stats.Totals.Honey = (stats.Totals.Honey or 0) + pollen
		end
		syncCoreStats(player)
		dirtyPlayers[player.UserId] = true
	end
end

reHandlers.BeeLevelUp = function(player, slotX, slotY)
	local stats = getPlayerData(player)
	if not stats or not stats.Honeycomb then return end
	local beeFile = HoneycombFileTools.GetBeeFile(stats.Honeycomb, slotX, slotY)
	if not beeFile then return end
	local lvl = beeFile.Lvl or 1
	if lvl >= BeeStats.MaxLevel then return end
	if (beeFile.Bond or 0) < BeeStats.LvlToTotalBond(lvl + 1) then return end
	beeFile.Lvl = lvl + 1; dirtyPlayers[player.UserId] = true
end

reHandlers.CompleteQuest = function(player, questId)
	local stats = getPlayerData(player)
	if not stats or not stats.Quests then return end
	for i, quest in ipairs(stats.Quests) do
		if quest == questId or (type(quest) == "table" and quest.ID == questId) then table.remove(stats.Quests, i); break end
	end
	if stats.Totals then StatTools.IncrementTotal(stats, "QuestsCompleted") end
	dirtyPlayers[player.UserId] = true
end

reHandlers.CompleteQuestFromPool = function(player, poolName, questId) reHandlers.CompleteQuest(player, questId) end

reHandlers.GiveQuest = function(player, questData)
	local stats = getPlayerData(player)
	if not stats then return end
	if not stats.Quests then stats.Quests = {} end
	table.insert(stats.Quests, questData); dirtyPlayers[player.UserId] = true
end

reHandlers.GiveQuestFromPool = function(player, poolName) reHandlers.GiveQuest(player, { ID = "Placeholder", Pool = poolName }) end

reHandlers.PlayerPurchase = function(player, itemKey, cost)
	local stats = getPlayerData(player)
	if not stats then return end
	local honey = stats.Honey or 0
	if honey < cost then return end
	stats.Honey = honey - cost
	if not stats.Items then stats.Items = {} end
	stats.Items[itemKey] = true
	syncCoreStats(player)
	dirtyPlayers[player.UserId] = true
end

reHandlers.ToolCollect = function(player, collectibleType, amount)
	amount = amount or 1
	local stats = getPlayerData(player)
	if not stats then return end

	if collectibleType == "Pollen" or collectibleType == nil then
		local capacity = PollenTools.GetCapacity(player)
		local currentPollen = stats.Pollen or 0
		if currentPollen < capacity then
			local toCollect = math.min(amount, capacity - currentPollen)
			stats.Pollen = currentPollen + toCollect
			if stats.Totals and stats.Totals.Pollen then
				stats.Totals.Pollen.All = (stats.Totals.Pollen.All or 0) + toCollect
			end
		end
	else
		if stats.Totals then StatTools.IncrementTotal(stats, collectibleType, amount) end
	end

	syncCoreStats(player)
	dirtyPlayers[player.UserId] = true
end

reHandlers.PlayerTakeDamage = function(player, damageAmount)
	local character = player.Character
	if not character then return end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health > 0 then humanoid:TakeDamage(damageAmount) end
end

reHandlers.ItemUseCommand = function(player, itemKey)
	local stats = getPlayerData(player)
