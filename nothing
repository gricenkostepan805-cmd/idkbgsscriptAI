-- =========================================================================

local function setupCoreStats(player, baseData)
	-- leaderstats for the player list
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local honeyVal = Instance.new("NumberValue")
	honeyVal.Name = "Honey"
	honeyVal.Value = baseData.Honey or 10000
	honeyVal.Parent = leaderstats

	-- CoreStats folder
	local coreStats = Instance.new("Folder")
	coreStats.Name = "CoreStats"
	coreStats.Parent = player

	local statsToCreate = {
		{"Honey", baseData.Honey or 10000},
		{"Pollen", 0},
		{"Capacity", baseData.Capacity or 200},
		{"TotalHoney", baseData.TotalHoney or 10000},
		{"DailyHoney", baseData.DailyHoney or 10000},
		{"Tickets", baseData.Tickets or 10}
	}

	for _, data in ipairs(statsToCreate) do
		local val = Instance.new("NumberValue")
		val.Name = data[1]
		val.Value = data[2]
		val.Parent = coreStats
	end
end

local function onPlayerAdded(player)
	-- Load player data
	local _, baseData = DataStoreModule.Load("BSS_Alpha_Save_v1", player.UserId)
	baseData.EquippedParachute = baseData.EquippedParachute or "None"
	playerCache[player] = baseData

	-- Set up CoreStats and leaderstats
	setupCoreStats(player, baseData)

	-- Create OOP player object
	pcall(function()
		activePlayerObjects[player] = PlayerTools.new(player)
	end)

	-- Equip gear when character spawns
	player.CharacterAdded:Connect(function(character)
		task.wait(1.5)

		-- Equip collector tool and backpack via PlayerTools OOP
		if activePlayerObjects[player] and activePlayerObjects[player].EquipGear then
			pcall(function() activePlayerObjects[player]:EquipGear() end)
		end

		-- Sync CoreStats with PollenTools
		pcall(function() PollenTools.SyncCoreStats(player) end)
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Handle players already in the game
for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, player)
end

Players.PlayerRemoving:Connect(function(player)
	local pData = playerCache[player]
	if pData then
		pcall(function() DataStoreModule.WaitUntilSave("BSS_Alpha_Save_v1", player.UserId, pData) end)
	end
	playerCache[player] = nil
	if activePlayerObjects[player] then
		pcall(function() activePlayerObjects[player]:Destroy() end)
		activePlayerObjects[player] = nil
	end
end)

print("[SERVER BOOT] BSS Server Engine initialized. Loading screen will close naturally when client receives stats.")
