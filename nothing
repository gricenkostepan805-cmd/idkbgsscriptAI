-- =========================================================================
-- BSS SERVER ENGINE - Canonical Events.ServerListen API
-- Does NOT touch the loading screen. The client's InitGui will call
-- LoadingGui.Hide() naturally once RetrievePlayerStats returns data.
-- =========================================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Workspace = game:GetService("Workspace")

-- Require server modules
local DataStoreModule = require(ServerStorage:WaitForChild("DataStore"))
local PlayerTools = require(ServerStorage:WaitForChild("PlayerTools"))
local PollenTools = require(ServerStorage:WaitForChild("PollenTools"))
local PlayerStatManager = require(ServerStorage:WaitForChild("PlayerStatManager"))

-- Require the canonical Events module (scans its own children for remotes)
local Events = require(ReplicatedStorage:WaitForChild("Events"))

-- Ensure ServerVersion exists (ClientInit does WaitForChild on this)
if not Workspace:FindFirstChild("ServerVersion") then
	local sv = Instance.new("StringValue")
	sv.Name = "ServerVersion"
	sv.Value = "621"
	sv.Parent = Workspace
end

-- Player data cache
local playerCache = {}
local activePlayerObjects = {}

-- Expose GetPlayerData for PlayerStatManager integration
local function GetPlayerData(player)
	return playerCache[player]
end
PlayerStatManager.SetMainServer({ GetPlayerData = GetPlayerData })

-- Honeycomb bridge: some scripts reference workspace.Honeycomb
pcall(function()
	local liveHoneycombs = Workspace:FindFirstChild("Honeycombs")
	if liveHoneycombs and not Workspace:FindFirstChild("Honeycomb") then
		local bridge = Instance.new("ObjectValue")
		bridge.Name = "Honeycomb"
		bridge.Value = liveHoneycombs
		bridge.Parent = Workspace
	end
end)

-- =========================================================================
-- REMOTE FUNCTION HANDLERS via Events.ServerListen
-- These use the canonical Events module API, which sets OnServerInvoke
-- on the RemoteFunction children of the Events ModuleScript.
-- =========================================================================

-- RetrievePlayerStats: Full player data table (critical for loading)
-- ClientStatCache:Get() invokes this. If it returns nil, the loading
-- screen never hides and the game freezes.
Events.ServerListen("RetrievePlayerStats", function(player)
	local data = playerCache[player] or DataStoreModule.NewPlayerData()
	return data
end)

-- RetrievePlayerStat: Individual stat lookup
Events.ServerListen("RetrievePlayerStat", function(player, statName)
	local data = playerCache[player] or DataStoreModule.NewPlayerData()
	if type(statName) == "string" then
		return data[statName] or 0
	elseif type(statName) == "table" then
		local current = data
		for _, key in ipairs(statName) do
			if type(current) == "table" then
				current = current[key]
			else
				return 0
			end
		end
		return current or 0
	end
	return 0
end)

-- RetrieveCachedPlayerStat: Same as RetrievePlayerStat
Events.ServerListen("RetrieveCachedPlayerStat", function(player, statName)
	local data = playerCache[player] or DataStoreModule.NewPlayerData()
	if type(statName) == "string" then
		return data[statName] or 0
	end
	return 0
end)

-- RetrievePlayerStatsSummary: Summary stats for UI
Events.ServerListen("RetrievePlayerStatsSummary", function(player)
	local pData = playerCache[player] or DataStoreModule.NewPlayerData()
	return {
		Honey = pData.Honey or 0,
		TotalHoney = pData.TotalHoney or 0,
		DailyHoney = pData.DailyHoney or 0,
		BeesDiscovered = (pData.Totals and pData.Totals.TotalBeesDiscovered) or 0,
		BadgesEarned = 0
	}
end)

-- RetrievePlayerStatsIntervalBackups: Interval data for leaderboards
Events.ServerListen("RetrievePlayerStatsIntervalBackups", function(player)
	local defaultPollen = {
		All = 0, Colors = { Red = 0, White = 0, Blue = 0 },
		Zones = {}, ByTag = {}, ZoneColors = {}
	}
	return {
		Day = {
			ID = 1,
			Stats = {},
			Totals = {
				Honey = 0, honey = 0,
				FarmedHoney = 0, farmedHoney = 0,
				ChallengeHoney = 0,
				TotalBeesDiscovered = 0,
				TotalGiftedBeesDiscovered = 0,
				Pollen = defaultPollen, pollen = defaultPollen,
				ChallengePollen = defaultPollen,
				Kills = {}
			}
		}
	}
end)

