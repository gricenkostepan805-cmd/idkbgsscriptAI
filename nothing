reHandlers.PlayerHiveCommand = function(player, command, ...)
	local stats = getPlayerData(player)
	if not stats then return end

	if command == "Convert" then
		local pollen = stats.Pollen or 0
		if pollen > 0 then
			stats.Honey = (stats.Honey or 0) + pollen
			if stats.Totals then
				stats.Totals.Honey = (stats.Totals.Honey or 0) + pollen
			end
			stats.Pollen = 0
			syncCoreStats(player)
			dirtyPlayers[player.UserId] = true
		end
	elseif command == "Toggle" then
	end
end

