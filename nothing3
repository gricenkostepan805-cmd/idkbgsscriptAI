print("📍 [LINE 12] Ждем появление папки Events...")
local eventsModule = ReplicatedStorage:WaitForChild("Events")

local function getRemote(name, className)
	local target = eventsModule:FindFirstChild(name)
	if target and target.ClassName ~= className then
		target:Destroy()
		target = nil
	end
	if not target then
		target = Instance.new(className)
		target.Name = name
		target.Parent = eventsModule
	end
	return target
end

