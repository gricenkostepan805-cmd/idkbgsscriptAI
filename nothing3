print("📍 [LINE 104] Вспомогательные функции анатомии Dex...")
local function mkV(parent, vtype, name, val)
	local v = parent:FindFirstChild(name) or Instance.new(vtype)
	v.Name = name if val ~= nil then v.Value = val end v.Parent = parent return v 
end
local function mkFolder(parent, name)
	local f = parent:FindFirstChild(name) or Instance.new("Folder") f.Name = name f.Parent = parent return f 
end

local function buildBssAnatomy(targetParent, baseData)
	print("📍 [LINE 114] Вызов buildBssAnatomy для: " .. targetParent.Name)
	local coreStats = mkFolder(targetParent, "CoreStats")
	mkV(coreStats, "NumberValue", "Capacity", baseData.Capacity or 200)
	mkV(coreStats, "NumberValue", "Honey", baseData.Honey or 0)
	mkV(coreStats, "NumberValue", "Pollen", baseData.Pollen or 0)

	print("📍 [LINE 120] Цикл флагов трейда...")
	local tradeConfig = mkFolder(targetParent, "TradeConfig")
	local tradeFlags = { "CanTrade", "IsTrading", "RequestsEnabled" }

	for _, flagName in ipairs(tradeFlags) do
		local boolVal = tradeConfig:FindFirstChild(flagName) or Instance.new("BoolValue")
		boolVal.Name = flagName
		boolVal.Value = (flagName == "CanTrade" or flagName == "RequestsEnabled")
		boolVal.Parent = tradeConfig
	end
	mkV(targetParent, "ObjectValue", "ActivatableTarget")
	print("📍 [LINE 133] Финал buildBssAnatomy")
end
