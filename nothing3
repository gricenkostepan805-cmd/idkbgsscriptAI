local function initPlayer(plr)
	print("📦 [MainServer Core] Рождение сессии игрока: " .. plr.Name)

	local bd = {
		Honey = 10000, Capacity = 200, Pollen = 0, Tickets = 10, TotalHoney = 10000, DailyHoney = 0,
		PlayerMovespeed = 16, PlayerJumpPower = 50,
		Gear = { Collectors = { "Scooper" }, Bags = { "Pouch" } },
		EquippedCollector = "Scooper", EquippedBackpack = "Pouch",
		Eggs = { ["BasicEgg"] = 1, ["Basic Egg"] = 1 },
		Stickers = {}, StickerBook = { Owned = {}, Slots = 10, Used = 0 },
		Badges = {}, Bees = {}, OwnedBees = {}, Quests = {}, Honeycomb = { Owner = plr.Name, HiveId = 0, Bees = {} }
	}

	print("📍 [LINE 151] Запуск task.spawn DataStore.Load внутри плеера...")
	task.spawn(function()
		print("📍 [LINE 153] ФОН: Чтение DataStore...")
		local ok, res = pcall(function() if DS and DS.Load then return DS.Load("BSS_Alpha_Save_v3", plr.UserId) end return nil end)
		if ok and res and type(res) == "table" then
			res.Eggs = type(res.Eggs) == "table" and res.Eggs or bd.Eggs
			res.StickerBook = type(res.StickerBook) == "table" and res.StickerBook or bd.StickerBook
			res.Gear = type(res.Gear) == "table" and res.Gear or bd.Gear
			res.Quests = type(res.Quests) == "table" and res.Quests or bd.Quests
			bd = res
			if plr:FindFirstChild("CoreStats") then plr.CoreStats.Honey.Value = bd.Honey or 10000 end
			if plr:FindFirstChild("leaderstats") and plr.leaderstats:FindFirstChild("Honey") then plr.leaderstats.Honey.Value = bd.Honey or 10000 end
		end
		print("📍 [LINE 163] ФОН: Финал чтения DataStore")
	end)

	cache[plr] = bd
	print("📍 [LINE 167] Вызов buildBssAnatomy для игрока...")
	buildBssAnatomy(plr, bd)

	local ls = Instance.new("Folder") ls.Name = "leaderstats" ls.Parent = plr
	local hv = Instance.new("NumberValue") hv.Name = "Honey" hv.Value = bd.Honey or 10000 hv.Parent = ls

	print("📍 [LINE 173] Подключаем CharacterAdded...")
	plr.CharacterAdded:Connect(function(ch)
		print("📦 [MainServer Core] Персонаж спавнулся в Workspace. Дублируем статы в модель тела!")
		buildBssAnatomy(ch, bd)

		local humanoid = ch:WaitForChild("Humanoid", 5)
		if humanoid then
			humanoid.WalkSpeed = bd.PlayerMovespeed or 16
			humanoid.JumpPower = bd.PlayerJumpPower or 50
		end

		mkV(plr, "Vector3Value", "SpawnPos", ch:GetPivot().Position)
		mkV(ch, "Vector3Value", "SpawnPos", ch:GetPivot().Position)

		task.wait(1.5)
		pcall(function()
			eventsModule.ServerItemPackEvent:FireClient(plr, "Update", {Honey = bd.Honey, Pollen = bd.Pollen, Capacity = bd.Capacity})
			eventsModule.ServerItemPackEvent:FireClient(plr, "HiveInitReady", {HiveId = 0, Data = {}})
			eventsModule.ServerItemPackEvent:FireClient(plr, "SetupListenersReady", {Ready = true})
			eventsModule.ServerItemPackEvent:FireClient(plr, "ReplicationReady", {Ready = true})
		end)
		print("📍 [LINE 194] Конец выполнения CharacterAdded")
	end)
	print("📍 [LINE 196] Конец выполнения функции initPlayer")
end

